		dnf="/usr/bin/dnf"
		forcednf4=""
		forcednf5=""
	fi

	# Handle email notifications and required package checks
	if [ "$notif_email" = "yes" ]; then
		if [ -f "$config" ]; then
			CECHO "[INFO]" "$vert" -n && echo -e " Lecture du fichier de configuration (${bleu}$config${reinit})."
			# shellcheck source=/dev/null
			source "$config" || true
		fi

		if [ -z "$email" ]; then
			DATE-ET-HEURE >> "$bigerror" || true
			CECHO "[WARN]" "$jaune" -n && { echo " Aucune adresse email trouvée." | tee -a "$bigerror" || true ;}
			CECHO "[INFO]" "$vert" -n && { echo " Veuillez exécuter la commande suivante pour créer le fichier de configuration :" | tee -a "$bigerror" || true ;}
			echo -e "	${gras}${bleu}$scriptfullname -C${reinit}" | tee -a "$bigerror" || true
			THE-END "des erreurs" | tee -a "$bigerror" || true
			exit 1
		else
			CECHO "[INFO]" "$vert" -n && echo -e " e-mail : ${bleu}$email${reinit}."
		fi

		if ! EXISTS mail; then
			DATE-ET-HEURE >> "$bigerror" || true
			CECHO "[ERR.]" "$rouge" -n && { echo -e " La commande ${gras}${bleu}mail${reinit} n'est pas disponible sur votre système." | tee -a "$bigerror" || true ;}
			CECHO "[INFO]" "$vert" -n && { echo -e " Vous pouvez l'installer avec la commande : ${gras}${bleu}sudo dnf install s-nail${reinit}." | tee -a "$bigerror" || true ;}
			CECHO "[WARN]" "$jaune" -n && { echo -e " Vous devez aussi installer et configurer un \"Mail Transport Agent\", par exemple ${gras}${bleu}msmtp${reinit} avec la commande ${gras}${bleu}sudo dnf install msmtp${reinit}." | tee -a "$bigerror" || true ;}
		fi
	fi

	# Check-only mode handling
	if [ "$checkonly" = "yes" ]; then
		CECHO "[INFO]" "$vert" -n && echo -e " $modeC (${vert}-c${reinit})."
		if [ "$notif_email" = "yes" ]; then
			if [ "$terminal" = "dumb" ]; then
				CECHO "[INFO]" "$vert" -n && echo -e " $modeM (${vert}-m${reinit})."
			else
				CECHO "[INFO]" "$vert" -n && echo -e " $modeM (${vert}-m${reinit}) ignoré car le script est lancé dans un terminal interactif."
				notif_email=""
			fi
		fi
		[ "$notif" = "yes" ] && { CECHO "[INFO]" "$vert" -n ; echo -e " $modeN (${vert}-n${reinit})."; }
	else
		# Ignore notifications if check-only mode is not activated
		if [ "$notif_email" = "yes" ]; then
			CECHO "[INFO]" "$vert" -n && echo -e " $modeM (${vert}-m${reinit}) ignoré car le $modeC (${vert}-c${reinit}) n'est pas activé."
			notif_email=""
		fi
		if [ "$notif" = "yes" ]; then
			CECHO "[INFO]" "$vert" -n && echo -e " $modeN (${vert}-n${reinit}) ignoré car le $modeC (${vert}-c${reinit}) n'est pas activé."
			notif=""
		fi
	fi
	[ "$norpm" = "" ] && INIT-LOGRPM
	return 0
}
################################################################################################################################
LOG-ROTATE() {
    declare -i max_logs=10
    local -A log_prefixes=(
        [log]="$log"
        [logFP]="$logFP"
        [logerror]="$logerror"
        [logerrorFP]="$logerrorFP"
        [bigerror]="$bigerror"
    )
    for key in "${!log_prefixes[@]}"; do
        local prefix="${log_prefixes[$key]}"
        # Supprime le fichier de log le plus ancien s'il existe (par exemple, .log.(max_logs-1))
        local oldest_log="$datadir/${prefix}.log.$((max_logs - 1))"
        if [[ -e "$oldest_log" ]]; then
            rm -f "$oldest_log" || { echo "Échec lors de la suppression de $oldest_log" >&2; return 1; }
        fi
        # Décale les fichiers de log existants d'un suffixe, en commençant par le suffixe le plus élevé jusqu'à .log.1
        for (( i=max_logs-2; i>=1; i-- )); do
            local old_log="$datadir/${prefix}.log.$i"
            local new_log="$datadir/${prefix}.log.$((i + 1))"
            if [[ -e "$old_log" ]]; then
                mv "$old_log" "$new_log" || { echo "Échec lors du renommage de $old_log en $new_log" >&2; return 1; }
            fi
        done
        # Renomme le fichier .log actuel en .log.1 s'il existe
        if [[ -e "$datadir/${prefix}.log" ]]; then
            mv "$datadir/${prefix}.log" "$datadir/${prefix}.log.1" || { echo "Échec lors du renommage de ${prefix}.log en ${prefix}.log.1" >&2; return 1; }
        fi
        # Met à jour la variable globale pour qu'elle pointe vers le fichier de log actuel, qui est toujours .log
        eval "$key=\"$datadir/${prefix}.log\""
    done
}
