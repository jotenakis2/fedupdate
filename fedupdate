################################################################################################################################
CLEAR-LOGS() {
	local fiche
	nblog=0
	listlog=""
	rm -f "$list" "$listFP"
	for fiche in "$logerrorFP" "$logerror" "$log" "$logFP" "$bigerror"; do
		if [ "$nolog" = "yes" ]; then
			rm -f "$fiche"
		else
			if [ ! -s "$fiche" ]; then # suppression si vide
				rm -f "$fiche"
			else # on compte le nb de log, on ajoute la date ; et on les concatène pour afficher
				nblog=$(( nblog + 1 ))
				echo >> "$fiche"
				DATE-ET-HEURE >> "$fiche"
				listlog="${listlog}${fiche} "
			fi
		fi
	done
}
################################################################################################################################
THE-END() {
	echo
	CLEAR-LOGS
	# Display available logs
	PRINTBANNER-CENTERED "" "." "$cyan"
	case $nblog in
		0) echo -n ;;
		1) CECHO "[INFO]" "$vert" -n ; echo " Log : $listlog" || true ;;
		*) CECHO "[INFO]" "$vert" -n ; echo " Logs : $listlog" || true ;;
	esac
	# Final message
	CECHO "[INFO]" "$vert" -n && echo -e " Script terminé avec $1 à $(DATE-ET-HEURE)."
	PRINTBANNER-CENTERED "" "*" "$gras$bleu"
	return 0
}
