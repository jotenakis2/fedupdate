################################################# dnf COMMANDS #################################################################
DNF_CLEANCMD() { # nettoyage complet du cache
	if [ "$silent" = "yes"  ]; then
		# en mode pseudosilencieux je n'affiche rien, je stocke les erreurs et la sortie.
		# shellcheck disable=SC2024
		sudo $dnf clean all >>"$log" 2>>"$logerror" || true
	else
		echo -e "$gris"
		# en mode normal j'affiche tout en gris, je stocke les erreurs et la sortie.
		# shellcheck disable=SC2024
		sudo $dnf clean all > >(tee -a "$log") 2> >(tee -a "$logerror" >&2) || true
		echo -ne "$reinit"
	fi
return 0
}
#-------------------------------------------------------------------------------------------
DNF_CACHEUPDCMD() { # création du cache
	if [ "$silent" = "yes"  ]; then
		# en mode pseudosilencieux je n'affiche rien, je stocke les erreurs et la sortie; et je met un spinner d'attente.
		{ trap STOP-SPINNER EXIT && START-SPINNER; }
			# shellcheck disable=SC2024
			sudo $dnf makecache >>"$log" 2>>"$logerror" || true
		{ STOP-SPINNER && echo "terminée."; }
	else
		echo -ne "$gris"
		# en mode normal j'affiche tout en gris, je stocke les erreurs et la sortie, pas de spinner d'attente.
		# shellcheck disable=SC2024
		sudo $dnf makecache > >(tee -a "$log") 2> >(tee -a "$logerror" >&2) || true
		echo -ne "$reinit"
	fi
return 0
}
#-------------------------------------------------------------------------------------------
DNF_CHECKUPDCMD() { # vérification de la présence de mise à jour
	if [ "$silent" = "yes"  ]; then
		# en mode pseudosilencieux je n'affiche rien, je stocke les erreurs et la liste des upd et je met un spinner d'attente
		{ trap STOP-SPINNER EXIT && START-SPINNER; }
			# shellcheck disable=SC2024
			sudo $dnf check-update $changelog -q >"$listtmp" 2>>"$logerror" || true
		{ STOP-SPINNER && echo "terminée."; }
	else
		# en mode normal, j'affiche tout en gris, je stocke les erreurs et la liste des upd (nettoyée)")
		echo -e "$gris"
		# shellcheck disable=SC2024
		sudo $dnf check-update $changelog -q > >(tee "$listtmp" | sed '/^$/d') 2> >(tee -a "$logerror" >&2) || true
		echo -ne "$reinit"
	fi
	sed -i '/.*|.*|.*|.*/d' "$listtmp" # parfois l'option -q déconne avec dnf5 donc je nettoie
	sed '/^Changelogs/ {x;p;x}' "$listtmp" >> "$log"
	sed -i '/^$/d' "$listtmp"
	return 0
}
