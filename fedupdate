################################################################################################################################
SUDOPASS() {
    local me
    me="$(whoami)"
    if ! sudo -n true 2>/dev/null; then          # si sudo a besoin du mot de passe
        if [[ -f "${passwordencrypted}" ]]; then # mot de passe chiffré
            if DECRYPT-PASS; then
                echo "${password}" | sudo -S echo -n >/dev/null 2>&1
            else
                CECHO "[WARN]" "${jaune}" -n
                echo -e " Erreur de déchiffrement du mot de passe de ${gras}${me}${reset}"
                CECHO "[INFO]" "${vert}" -n
                echo -e " Vous pourrez lancer ${gras}${bleu}${scriptfullname} -C${reset} pour refaire le chiffrement."
                CECHO "[INFO]" "${vert}" -n
                echo -e " On poursuit le déroulement de ${gras}${bleu}${scriptname}${reset}."
                if [[ "${terminal}" != "dumb" ]]; then
                    CECHO "[ACT.]" "${magenta}" -n
                    echo -ne " Veuillez saisir le mot de passe de ${gras}${bleu}${me}${reset} (sudo) : "
                    PASSWORD_INPUT || return 1
                    echo "${password}" | sudo -S echo -n >/dev/null 2>&1
                else
                    echo " Le déchiffrement du mot de passe a échoué." | tee -a "${bigerror}"
                    END "des erreurs"
                    exit 1
                fi
            fi
        else # mot de passe en clair ou encrypté mais le fichier n'existe plus
            if [[ "${terminal}" = "dumb" ]]; then
                if [[ -n "${password}" ]] && [[ "${password}" != "***EnCrYpTed***" ]]; then
                    echo "${password}" | sudo -S echo -n >/dev/null 2>&1
                else
                    echo " Le mot de passe n'est plus stocké. Veuillez relancer ${scriptfullname} -C pour recréer le fichier de configuration" | tee -a "${bigerror}"
                    END "des erreurs"
                    exit 1
                fi
            else
                if [[ -n "${password}" ]] && [[ "${password}" != "***EnCrYpTed***" ]]; then # le mdp existe on l'envoie à sudo
                    echo "${password}" | sudo -S echo -n >/dev/null 2>&1
                else # le mdp n'existe pas on le demande à l'utilisateur
                    CECHO "[WARN]" "${jaune}" -n
                    echo -e " Le mot de passe n'est plus stocké. Il faudra relancer ${gras}${bleu}${scriptfullname} -C${reset} pour recréer le fichier de configuration."
                    CECHO "[INFO]" "${vert}" -n
                    echo -e " On poursuit le déroulement de ${gras}${bleu}${scriptname}${reset}."
                    CECHO "[ACT.]" "${magenta}" -n
                    echo -ne " Veuillez saisir le mot de passe de ${gras}${bleu}${me}${reset} (sudo) : "
                    PASSWORD_INPUT || return 1
                    echo "${password}" | sudo -S echo -n >/dev/null 2>&1
                fi
            fi
        fi
    fi
    return 0
}
################################################################################################################################
TIMER-BAR() {
    local duree="${1}"       # en secondes
    local largeur="${2}"     # largeur de la barre de progression
    local message_fin="${3}" # message final
    local couleur="${4}"     # couleur de l'ensemble
    local remplissage
    local bar
    local vide
    local temps_restant
    local index

    echo -ne "${couleur}"
    for ((index = 0; index <= duree; index++)); do
        remplissage=$((index * largeur / duree))
        bar=$(printf "%-${remplissage}s" "" | tr ' ' '#')              # Filled part
        vide=$(printf "%-$((largeur - remplissage))s" "" | tr ' ' '.') # Empty part
        temps_restant=$((duree - index))                               # Calculate seconds remaining
        if ((temps_restant == 0)); then
            echo -ne "\r[${bar}${vide}]              \r"
            echo -ne "${message_fin}"
        elif ((temps_restant == 1)); then
            echo -ne "\r[${bar}${vide}] ${temps_restant}s restante   "
        else
            echo -ne "\r[${bar}${vide}] ${temps_restant}s restantes   "
        fi
        sleep 1
    done
    echo -e "${reset}"
}
