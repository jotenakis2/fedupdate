}
################################################################################################################################
INSTALLED_DISTRO(){
    local dateepoch
	if EXISTS stat; then
	    dateepoch="$(stat -c %W "/etc")"
		days_since_install=$(( ( $(date +%s) - $(date +%s -d @"$dateepoch") ) / 86400 ))
		datecreated=$(date -d @"$dateepoch" +"%A %d %B %Y")
		if [ $days_since_install -eq 1 ]; then
		  day="jour"
		else
		  day="jours"
		fi
	else
	    datecreated="inconnue"
	fi
	return 0
}
################################################################################################################################
OFFLINE-UPGRADE() {
	local delay=6
	local largeur=42
	CECHO "[INFO]" "$vert" -n && echo -n " TĂŠlĂŠchargement des paquets "
	{ trap STOP-SPINNER EXIT && START-SPINNER; }
		# shellcheck disable=SC2024
		sudo $dnf -y offline-upgrade download >"$log" 2>"$logerror"
	{ STOP-SPINNER && echo "terminĂŠ."; }
	if [ "$silent" = "" ]; then $bat "$log"; else $bat "$list"; fi
	# gestion des erreurs de tĂŠlĂŠchargement
	if [ -s "$logerror" ]; then
		echo
		CECHO "[WARN]" "$jaune" -n && echo " Le tĂŠlĂŠchargement a rencontrĂŠ des erreurs (pas forcĂŠment grave) : "
		$bat "$logerror"
		if ! ASK-YESNO "" "$vert" " Voulez-vous continer (oui/non) ? " "$magenta" ""; then
			THE-END "des erreurs"
			exit 1
		fi
	fi
	if ASK-YESNO " Le script va maintenant redĂŠmarrer le systĂ¨me et faire la mise Ă  jour hors-ligne." "$vert" " Ătes-vous d'accord (oui/non) ? " "$magenta" "[INFO]"; then
		echo
		PRINTBANNER-CENTERED "" "." "$cyan"
		CECHO "[INFO]" "$vert" -n && echo " Script terminĂŠ avec succĂ¨s Ă  $(DATE-ET-HEURE)."
		CECHO "[INFO]" "$vert" -n && echo " L'ordinateur va redĂŠmarrer dans ${delay}s :"
		COMPTEUR $delay $largeur "RedĂŠmarrage !" "$vert" "$rouge" "$cyan" "$cyan"
		PRINTBANNER-CENTERED "" "*" "$gras$bleu"
		touch "$offlineindicator"  # ce fichier sera dĂŠtectĂŠ par un service systemd aprĂ¨s reboot pour afficher un message
		sleep 0.5 && sudo $dnf offline-upgrade reboot
	else
		if ASK-YESNO " RedĂŠmarrage annulĂŠ par l'utilisateur... " "$vert" " Voulez-vous supprimer les paquets tĂŠlĂŠchargĂŠs non installĂŠs (oui/non) ? " "$magenta" "[INFO]"; then
			SUDOPASS
			# shellcheck disable=SC2024
			sudo $dnf offline-upgrade clean >> "$log"
			CECHO "[INFO]" "$vert" -n && echo " Tous les paquets du cache de mise Ă  jour hors-ligne ont ĂŠtĂŠ effacĂŠs."
		else
			CECHO "[INFO]" "$vert" -n && echo " Vous pouvez utiliser la commande 'sudo dnf offline-upgrade reboot' pour terminer manuellement la mise Ă  jour."
		fi
	fi
	return 0
}
