    if [[ -s "${logerror}" ]]; then
        if grep -iqE "${pattern_error}" "${logerror}"; then
            error="yes"
            echo
            CECHO "[INFO]" "${vert}" -n
            echo " La mise à jour directe semble avoir rencontré des erreurs : "
            echo -en "${gris}"
            echo "------------------------"
            ${bat} "${logerror}"
            echo "------------------------"
            echo -en "${reset}"
        fi
    fi
    if [[ "${poweroff}" = "yes" ]]; then
        CECHO "[INFO]" "${vert}" -n
        echo -e " L'ordinateur va s'éteindre dans ${delay}s (argument ${vert}-p${reset}) :"
        TIMER-BAR "${delay}" "${largeur}" "==> Extinction de l'ordinateur <==" "${gras}${jaune}"
        sleep 1
        systemctl poweroff || true
    fi
    return 0
}
################################################################################################################################
SEND-EMAIL() {
    local subject="${1}"
    local body="${2}"
    export USERLOCAL="root"

    CECHO "[INFO]" "${vert}" -n
    echo -n " Envoi d'un email à ${email} "
    echo " => veuillez éxécuter la commande ${scriptfullname} sur ${host} pour procéder à la mise à jour." >>"${body}"
    { trap STOP-SPINNER EXIT && START-SPINNER; }
    LANG="${LANG0}" mail -s "${subject}" "${email}" <"${body}" || true
    { STOP-SPINNER && echo "terminé."; }
    return 0
}
################################################################################################################################
NOTIFY() {
    local type
    type="${1}"
    local liste
    liste="${2}"
    local message
    local icon
    local messagelong
    local tmp
    tmp="${HOME}/.cache/file.tmp"
    declare -i attempt=0
    declare -i max_attempts=9
    icon="/usr/share/swcatalog/icons/fedora/128x128/org.mageia.dnfdragora.png"
    message="Mises à jour disponibles"
    # Extract and format list for the notification
    awk '{print $1}' "${liste}" | sort -u | sed -E 's/\.aarch64$//; s/\.noarch$//; s/^org\.//' >"${tmp}"
    messagelong="$(tr '\n' ',' <"${tmp}" | sed 's/,/,   /g' | sed 's/[[:space:]]*,[[:space:]]*$/ /')" || messagelong="(Liste indisponible)"
    rm -f "${tmp}"
    unset "${tmp}"
    # Wait for D-Bus notifications to be ready (max 9 attempts)
    while ! dbus-send --session --dest=org.freedesktop.notifications --type=method_call \
        /org/freedesktop/notifications org.freedesktop.notifications.GetCapabilities >/dev/null 2>&1; do
        attempt=$((attempt + 1))
        if [[ ${attempt} -ge ${max_attempts} ]]; then
            DATE-ET-HEURE >>"${bigerror}"
            echo "Avertissement : D-Bus n'est toujours pas prêt après ${attempt} tentatives. Continuation du script." >>"${bigerror}"
            break # Exit the loop and continue the script
        fi
        sleep 5
    done
    # Send notification
    notify-send -i "${icon}" -u critical --app-name "${scriptname} (${type})" "${message}" "${messagelong}" || true
    return 0
}
################################################################################################################################
DISTRO-UPGRADE() {
    echo
    PRINTBANNER-CENTERED "MISE À NIVEAU" "." "${cyan}"
    local -i VERSION_PLUS
    local -i VERSION
    local delay=5
    local largeur=15
    # shellcheck disable=SC2154
    VERSION=${VERSION_ID} # from /etc/os-release
    VERSION_PLUS=$((VERSION_ID + 1))
    CECHO "[INFO]" "${vert}" -n
    echo -e " Montée en version de ${gras}${host}${reset} de la version ${gras}${jaune}${VERSION}${reset} vers la version ${gras}${jaune}${VERSION_PLUS}${reset}."
    if ! ASK-YESNO " Validez-vous la version cible (${VERSION_PLUS}) ? " "${magenta}" "" "${magenta}" "[ACT.]"; then
        CECHO "[INFO]" "${vert}" -n
        echo -e "${gras} Montée en version annulée par l'utilisateur.${reset}"
        return 0
    fi
    DNF_UPGRADECMD "${VERSION_PLUS}"
    # Gestion des erreurs de téléchargement
    if [[ -s "${logerror}" ]]; then
        echo
        CECHO "[WARN]" "${jaune}" -n
        echo " La montée en version a rencontré des erreurs (pas forcément grave, veuillez vérifier) : "
        echo -ne "${gris}"
        echo "------------------------"
        ${bat} "${logerror}"
        echo "------------------------"
        echo -en "${reset}"
        if ! ASK-YESNO "" "${vert}" " Voulez-vous continuer" "${magenta}" ""; then
            END "des erreurs"
            exit 1
        fi
    fi
    if ASK-YESNO " Le script va maintenant redémarrer le système et faire la mise à jour hors-ligne." "${vert}" " Êtes-vous d'accord" "${magenta}" "[INFO]"; then
        echo
        CECHO "[INFO]" "${vert}" -n
        echo " L'ordinateur va redémarrer dans ${delay}s :"
        if [[ "${poweroff}" = "yes" ]]; then
            TIMER-BAR "${delay}" "${largeur}" "==> Redémarrage pour la mise à jour hors-ligne, puis arrêt de l'ordinateur <==" "${gras}${jaune}"
        else
            TIMER-BAR "${delay}" "${largeur}" "==> Redémarrage pour la mise à jour hors-ligne, puis allumage de l'ordinateur <==" "${gras}${jaune}"
        fi
        if DNF_CHECK_OFFLINE_UPGRADE_READY; then
            END "succès"
            sleep 2
            DNF_UPGRADE-REBOOTCMD
        else
            echo
            CECHO "[ERR.]" "${rouge}" -n
            echo " Le redémarrage n'est pas possible."
            SUDOPASS
            # shellcheck disable=SC2024
            sudo "${dnf}" offline-upgrade reboot >>"${logerror}" 2>&1
            END "des erreurs"
            exit 1
        fi
    else
        if ASK-YESNO " Redémarrage annulé par l'utilisateur... " "${vert}" " Voulez-vous supprimer les paquets téléchargés non installés" "${magenta}" "[INFO]"; then
            DNF_UPGRADE-CLEANCMD
            CECHO "[INFO]" "${vert}" -n
            echo " Tous les paquets du cache de mise à jour hors-ligne ont été effacés."
        else
            CECHO "[INFO]" "${vert}" -n
            echo " Vous pouvez utiliser la commande suivante pour terminer manuellement la mise à jour :"
            echo -e "${bleu}	sudo dnf offline-upgrade -y reboot${reset}"
            CECHO "[INFO]" "${vert}" -n
            echo " Vous pouvez utiliser la commande suivante pour supprimer manuellement les paquets téléchargés :"
            echo -e "${bleu}	sudo dnf offline-upgrade clean${reset}"
        fi
    fi
    return 0
}
################################################################################################################################
CHECKRPM() {
    listtmp="${HOME}/.cache/list.tmp"
    if [[ "${interactive}" = "yes" ]] && ! ASK-YESNO " Mode interactif: cache des métadonnées." "${surligne}${vert}" " Voulez-vous faire une mise à jour du cache des métadonnées" "${surligne}${magenta}" "[INFO]"; then
        nocacheupd="yes"
    fi
    [[ "${interactive}" = "yes" ]] && echo ""
    if [[ -z "${nocacheupd}" ]]; then
        CECHO "[INFO]" "${vert}" -n
        echo -n " Mise à jour forcée du cache des métadonnées "
        DNF_CLEANCMD
        DNF_CACHEUPDCMD
    fi
    CECHO "[INFO]" "${vert}" -n
    echo -n " Vérification des paquets disponibles "
    DNF_CHECKUPDCMD
    # Format and filter list of updates
    if [[ "${silent}" = "yes" ]] && [[ "${changelog}" = "yes" ]]; then
        ${bat} "${listtmp}"
    fi
    awk '/^Changelogs/ {exit} {if (NF > 0) printf "  %-45s %-7s\n", $1, $2}' "${listtmp}" >"${list}"
    #rm -f "${listtmp}"
    unset listtmp
    # Check for errors and output results
    if [[ -s "${logerror}" ]]; then
        if grep -iqE "${pattern_error}" "${logerror}"; then
            error="yes"
            CECHO "[ERR.]" "${rouge}" -n
            echo " La vérification a rencontré des erreurs :"
            echo -ne "${gris}"
            echo "------------------------"
            ${bat} "${logerror}"
            echo "------------------------"
            echo -en "${reset}"
            echo
            if ! ASK-YESNO "" "${vert}" " Voulez-vous continuer" "${magenta}" ""; then
                END "des erreurs"
                exit 1
            fi
        fi
    fi
    if [[ -s "${list}" ]]; then
        existupdateRPM="yes"
        return 0
    else
        return 1
    fi
}
################################################################################################################################
MANAGE-RPM() {
    echo
    PRINTBANNER-CENTERED "GESTION DES RPMs" "." "${cyan}"
    if CHECKRPM; then
        if [[ "${silent}" = "yes" ]] && [[ "${changelog}" = "" ]]; then
            ${bat} "${list}"
        fi
        if [[ -z "${checkonly}" ]]; then # mode normal
            [[ "${interactive}" = "yes" ]] && echo ""
            if [[ "${interactive}" = "yes" ]] && ASK-YESNO " Mode interactif: type de mise à jour." "${surligne}${vert}" " Voulez-vous faire une mise à jour directe" "${surligne}${magenta}" "[INFO]"; then
                    directrpms="yes"
                    echo ""
            fi
            if [[ "${directrpms}" = "yes" ]]; then
                ONLINE-UPGRADE
            else
                if [[ "${distrupgrade}" = "yes" ]]; then
                    CECHO "[INFO]" "${vert}" -n
                    echo -e " Le ${modeU} est ignoré pour le moment car des mises à jour sont à faire avant."
                    CECHO "[INFO]" "${vert}" -n
                    echo -e " Après la mise à jour vous pourrez relancer ${gras}${scriptfullname} -u${reset}."
                    distrupgrade=""
                fi
                OFFLINE-UPGRADE
            fi
        else # mode checkonly
            CECHO "[INFO]" "${vert}" -n
            echo " Des mises à jour sont disponibles."
            if [[ "${distrupgrade}" = "yes" ]]; then
                CECHO "[INFO]" "${vert}" -n
                echo -e " Le ${modeU} est ignoré pour le moment car des mises à jour sont à faire avant."
                CECHO "[INFO]" "${vert}" -n
                echo -e " Après la mise à jour vous pourrez relancer ${gras}${scriptfullname} -u${reset}."
                distrupgrade=""
            fi
            [[ "${notif}" = "yes" ]] && NOTIFY "RPM" "${list}"
            if [[ "${notif_email}" = "yes" ]] && [[ "${emailfpk}" = "yes" ]]; then
                local listemail=""
                listemail="${HOME}/.cache/listemail.tmp"
                echo >>"${listFP}"
                cat "${list}" "${listFP}" >"${listemail}"
                SEND-EMAIL "[${host}] Mise à jour" "${listemail}"
                sleep 1
                rm -f "${listemail}"
                unset listemail
            elif [[ "${notif_email}" = "yes" ]]; then
                SEND-EMAIL "[${host}] Mise à jour RPM" "${list}"
            elif [[ "${emailfpk}" = "yes" ]]; then
                SEND-EMAIL "[${host}] Mise à jour FLATPAK" "${listFP}"
            fi
        fi
    else
        CECHO "[INFO]" "${vert}" -n
        echo -e " ${gras}Votre système (${host}) est déjà à jour.${reset}"
    fi
    return 0
}
