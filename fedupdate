            echo "- ${modeN} (-n) ignoré car le ${modeC} (-c) n'est pas activé." >>"${biglog}"
            notif=""
        fi
    fi
    #----------------------------------

    # Contrôles du mode email (verif adresse email existe et commande mail est installée)
    if [[ "${notif_email}" = "yes" ]]; then
        if [[ "${nomail}" = "yes" ]]; then
            echo "- Le ${modeM} (-m) est incompatible avec le ${modeMM} (-M)." >>"${biglog}"
            echo "-> On ignore donc le ${modeM} (-m)." >>"${biglog}"
            notif_email=""
        fi
        if [[ -z "${email}" ]]; then
            DATE-ET-HEURE >>"${bigerror}"
            CECHO "[WARN]" "${jaune}" -n
            echo " Aucune adresse email trouvée." | tee -a "${bigerror}"
            echo "- Aucune adresse email trouvée." >>"${biglog}"
            CECHO "[INFO]" "${vert}" -n
            echo " Veuillez exécuter la commande suivante pour créer le fichier de configuration :" | tee -a "${bigerror}"
            echo -e "	${gras}${bleu}${scriptfullname} -C${reset}" | tee -a "${bigerror}"
            END "des erreurs" | tee -a "${bigerror}"
            exit 1
        else
            echo "- e-mail : ${email}." >>"${biglog}"
        fi
        if ! EXISTS mail; then
            DATE-ET-HEURE >>"${bigerror}"
            CECHO "[ERR.]" "${rouge}" -n
            echo -e " La commande ${gras}${bleu}mail${reset} n'est pas disponible sur votre système." | tee -a "${bigerror}"
            echo "- La commande mail n'est pas disponible sur votre système." >>"${biglog}"
            CECHO "[INFO]" "${vert}" -n
            echo -e " Vous pouvez l'installer avec la commande : ${gras}${bleu}sudo dnf install s-nail${reset}." | tee -a "${bigerror}"
            CECHO "[WARN]" "${jaune}" -n
            echo -e " Vous devez aussi installer et configurer un \"Mail Transport Agent\", par exemple ${gras}${bleu}msmtp${reset} avec la commande ${gras}${bleu}sudo dnf install msmtp${reset}." | tee -a "${bigerror}"
        fi
    fi
    #----------------------------------

    # Finalisation
    echo >>"${biglog}"
    dnfver="$(CHECK_DNF_VERSION || echo "unknown")"
    [[ "${norpm}" = "" ]] && INIT-LOGRPM
    echo -ne "${gris}"

    if [[ "${silent}" = "" ]]; then # en mode verbose j'affiche les données de traitement des options.
        #echo "${biglog}"
        grep "^-" "${biglog}" || true
    fi

    local opts allopts=""
    for opts in silent verbose help checkonly notif_email nomail notif noflatpak norpm norust nolog checkdeps directrpms nocacheupd \
        forcecacheupd poweroff nopoweroff changelog forcednf4 forcednf5 distrupgrade limitlog deletelog interactive; do
        if [[ "${!opts}" = "yes" ]]; then
            allopts="--${opts} ${allopts}"
            #echo -n "--${opts} " | tee -a "${biglog}"
        fi
    done
    if [[ "${allopts}" != "" ]]; then
        CECHO "[INFO]" "${vert}" -n
        echo -e " Options retenues (arguments longs) : ${gras}${vert}${allopts}${reset}" | tee -a "${biglog}"
    fi
    #----------------------------------

    return 0
}
################################################################################################################################
LOG-ROTATE() {
    declare -i max_logs=50
    local key
    local -A log_prefixes=(
        [log]="${log}"
        [logFP]="${logFP}"
        [logRust]="${logRust}"
        [logerror]="${logerror}"
        [logerrorFP]="${logerrorFP}"
        [logerrorRust]="${logerrorRust}"
        [bigerror]="${bigerror}"
        [biglog]="${biglog}"
    )
    for key in "${!log_prefixes[@]}"; do
        local prefix="${log_prefixes[${key}]}"
        # Supprime le fichier de log le plus ancien s'il existe (par exemple, .log.(max_logs-1))
        local oldest_log="${datadir}/${prefix}.log.$((max_logs - 1))"
        if [[ -e "${oldest_log}" ]]; then
            rm -f "${oldest_log}" || {
                echo "Échec lors de la suppression de ${oldest_log}" >&2
                return 1
            }
        fi
        # Décale les fichiers de log existants d'un suffixe, en commençant par le suffixe le plus élevé jusqu'à .log.1
        for ((i = max_logs - 2; i >= 1; i--)); do
            local old_log="${datadir}/${prefix}.log.${i}"
            local new_log="${datadir}/${prefix}.log.$((i + 1))"
            if [[ -e "${old_log}" ]]; then
                mv "${old_log}" "${new_log}" || {
                    echo "Échec lors du renommage de ${old_log} en ${new_log}" >&2
                    return 1
                }
            fi
        done
        # Renomme le fichier .log actuel en .log.1 s'il existe
        if [[ -e "${datadir}/${prefix}.log" ]]; then
            mv "${datadir}/${prefix}.log" "${datadir}/${prefix}.log.1" || {
                echo "Échec lors du renommage de ${prefix}.log en ${prefix}.log.1" >&2
                return 1
            }
        fi
        # Met à jour la variable globale pour qu'elle pointe vers le fichier de log actuel, qui est toujours .log
        eval "${key}=\"${datadir}/${prefix}.log\""
    done
}
