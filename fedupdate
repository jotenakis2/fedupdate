DNF_CHECK_OFFLINE_UPGRADE_READY() {
    SUDOPASS
    local dnf_file=""
    if [[ "${dnfver}" == "dnf4" ]]; then
        dnf_file="/var/lib/dnf/system-upgrade/system-upgrade-transaction.json"
    else
        dnf_file="/usr/lib/sysimage/libdnf5/offline/transaction.json"
    fi
    if sudo test -f "${dnf_file}" &>/dev/null; then # je teste la présence du fichier en root car ${USER} n'a pas les droits
        return 0
    else
        return 1
    fi
}
