DNF_UPGRADECMD() {
    SUDOPASS
    local -i TARGET
    TARGET=$1
    echo -ne "${gris}"
    if [[ "${dnfver}" == "dnf4" ]]; then
        # shellcheck disable=SC2024
        sudo "${dnf}" -y system-upgrade download --allowerasing --setopt=module_platform_id=platform:f"${TARGET}" --releasever="${TARGET}" > >(tee -a "${log}") 2> >(tee -a "${logerror}" >&2) || true
    else
        # shellcheck disable=SC2024
        sudo "${dnf}" -y system-upgrade download --setopt=module_platform_id=platform:f"${TARGET}" --releasever="${TARGET}" > >(tee -a "${log}") 2> >(tee -a "${logerror}" >&2) || true
    fi
