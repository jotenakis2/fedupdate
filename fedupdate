################################################################################################################################
OFFLINE-UPGRADE() {
	local delay=6
	local largeur=42
	CECHO "[INFO]" "$vert" -n && echo -n " Téléchargement des paquets "
	DNF_OFF-UPDATECMD
	#if [ "$silent" = "yes" ]; then
	#	$bat "$list" || true
	#fi
	# Gestion des erreurs de téléchargement
	if [ -s "$logerror" ]; then
		echo
		CECHO "[WARN]" "$jaune" -n && echo " Le téléchargement a rencontré des erreurs (pas forcément grave) : "
		$bat "$logerror" || true
		if ! ASK-YESNO "" "$vert" " Voulez-vous continuer (oui/non) ? " "$magenta" ""; then
			THE-END "des erreurs" || true
			exit 1
		fi
	fi
	if ASK-YESNO " Le script va maintenant redémarrer le système et faire la mise à jour hors-ligne." "$vert" " Êtes-vous d'accord (oui/non) ? " "$magenta" "[INFO]"; then
		echo
		THE-END "succès" || true
		CECHO "[INFO]" "$vert" -n && echo " L'ordinateur va redémarrer dans ${delay}s :"
		if [ "$poweroff" = "yes" ]; then
			COMPTEUR $delay $largeur "Redémarrage pour la mise à jour hors-ligne, puis arrêt de l'ordinateur..." "$vert" "$rouge" "$cyan" "$cyan" || true
		else
			COMPTEUR $delay $largeur "Redémarrage pour la mise à jour hors-ligne, puis allumage de l'ordinateur..." "$vert" "$rouge" "$cyan" "$cyan" || true
		fi
		echo "$dnf" > "$offlineindicator" || true  # Ce fichier sera détecté par un service systemd après reboot pour afficher un message
		sleep 2 || true
		DNF_OFF-REBOOTCMD || true
	else
		if ASK-YESNO " Redémarrage annulé par l'utilisateur... " "$vert" " Voulez-vous supprimer les paquets téléchargés non installés (oui/non) ? " "$magenta" "[INFO]"; then
			SUDOPASS
			DNF_OFF-CLEANCMD || true
			CECHO "[INFO]" "$vert" -n && echo " Tous les paquets du cache de mise à jour hors-ligne ont été effacés."
		else
			CECHO "[INFO]" "$vert" -n && echo " Vous pouvez utiliser la commande suivante pour terminer manuellement la mise à jour :"
			echo -e "${bleu}	sudo dnf offline-upgrade -y reboot${reinit}"
			CECHO "[INFO]" "$vert" -n && echo " Vous pouvez utiliser la commande suivante pour supprimer manuellement les paquets téléchargés :"
			echo -e "${bleu}	sudo dnf offline-upgrade clean${reinit}"
		fi
	fi
	return 0
}
################################################################################################################################
ONLINE-UPGRADE() {
	local delay=6
	local largeur=42
	CECHO "[INFO]" "$vert" -n && echo -n " Téléchargement des paquets et mise à jour directe "
	DNF_UPDATECMD
	if [ "$silent" = "yes" ]; then
		$bat "$list" || true
	fi
	# Gestion des erreurs de téléchargement
	if [ -s "$logerror" ]; then
		echo
		CECHO "[WARN]" "$jaune" -n && echo " La mise à jour directe a rencontré des erreurs (pas forcément grave) : "
		$bat "$logerror" || true
		if ! ASK-YESNO "" "$vert" " Voulez-vous continuer (oui/non) ? " "$magenta" ""; then
			THE-END "des erreurs" || true
			exit 1
		fi
	fi
	if [ "$poweroff" = "yes" ]; then
		CECHO "[INFO]" "$vert" -n && echo " L'ordinateur va s'éteindre dans ${delay}s (argument ${vert}-p${reinit}) :"
		COMPTEUR $delay $largeur "Extinction de l'ordinateur." "$vert" "$rouge" "$cyan" "$cyan" || true
		sleep 1 || true
		systemctl poweroff || true
	fi
	return 0
}
################################################################################################################################
SEND-EMAIL() {
	local type="$1" # RPM ou FP
	local liste="$2"
	export USERLOCAL="root"

	CECHO "[INFO]" "$vert" -n && echo -n " Envoi d'un email à $email "
	echo " => veuillez éxécuter la commande ${scriptfullname} sur $host pour procéder à la mise à jour." >> "$liste" || true
	{ trap STOP-SPINNER EXIT && START-SPINNER; }
		mail -s "[$host] Des mises à jour $type sont disponibles" "$email" < "$liste" || true
	{ STOP-SPINNER && echo "terminé."; }
	return 0
}
################################################################################################################################
GESTION-NOTIF() {
	local type="$1"
	local liste="$2"
	local message
	local icon
	local messagelong
	local tmp="/tmp/file.tmp"
	declare -i attempt=0
	declare -i max_attempts=9
	icon="/usr/share/swcatalog/icons/fedora/128x128/org.mageia.dnfdragora.png"
	message="Exécutez le programme $scriptfullname pour mettre à jour :"
	# Extract and format list for the notification
	awk '{print $1}' "$liste" | sort -u | sed -E 's/\.aarch64$//; s/\.noarch$//; s/^org\.//' > "$tmp" || true
	messagelong=$(tr '\n' ',' < "$tmp" | sed 's/,/,   /g' | sed 's/[[:space:]]*,[[:space:]]*$/ /') || messagelong="(Liste indisponible)"
	rm -f "$tmp"

	# Wait for D-Bus notifications to be ready (max 9 attempts)
	while ! dbus-send --session --dest=org.freedesktop.notifications --type=method_call \
			/org/freedesktop/notifications org.freedesktop.notifications.GetCapabilities >/dev/null 2>&1; do
		attempt=$((attempt + 1))
		if [ $attempt -ge $max_attempts ]; then
			DATE-ET-HEURE >> "$bigerror"
			echo "Avertissement : D-Bus n'est toujours pas prêt après $attempt tentatives. Continuation du script." >> "$bigerror" || true
			break  # Exit the loop and continue the script
		fi
		sleep 5 || true
	done
	# Send notification
	notify-send -i "$icon" -u critical --app-name "Mises à jour système ($type)" "$message" "$messagelong" || true
	return 0
}
################################################################################################################################
CHECKRPM() {
	listtmp="/tmp/list.tmp"
	SUDOPASS
	if [ -z "$nocacheupd" ]; then
		CECHO "[INFO]" "$vert" -n && echo -n " Mise à jour forcée du cache des métadonnées "
		DNF_CLEANCMD
		DNF_CACHEUPDCMD
	fi
	CECHO "[INFO]" "$vert" -n && echo -n " Vérification des paquets disponibles "
	DNF_CHECKUPDCMD
	# Format and filter list of updates
	#sed '/^Changelogs/,$d' "$listtmp" | awk '{printf "%-45s %-7s\n", $1, $2}' | grep -v '^[[:space:]]*$' | sed 's/^/  /' > "$list" || true
	awk '/^Changelogs/ {exit} {if (NF > 0) printf "  %-45s %-7s\n", $1, $2}' "$listtmp" > "$list" || true
	rm -f "$listtmp"
	unset listtmp
	# Check for errors and output results
	if [ -s "$logerror" ]; then
		CECHO "[ERR.]" "$rouge" -n && echo " La vérification a échoué."
		if [ "$silent" = "yes" ]; then
			$bat "$logerror" || true
		else
			echo
		fi
		THE-END "des erreurs" || true
		exit 1
	fi
	if [ -s "$list" ]; then
		return 0
	else
		return 1
	fi
}
################################################################################################################################
GESTION-RPM() {
	echo
	PRINTBANNER-CENTERED "GESTION DES RPMs" "." "$cyan"
	if CHECKRPM; then
		if [ -n "$silent" ]; then
			$bat "$list" || true
		fi
		if [ -z "$checkonly" ]; then 	# mode normal
			if [ "$directrpms" = "yes" ]; then
				ONLINE-UPGRADE || true
			else
				OFFLINE-UPGRADE || true
			fi
		else  							# mode checkonly
			CECHO "[INFO]" "$vert" -n && echo " Des mises à jour sont disponibles."
			[ "$notif" = "yes" ] && { GESTION-NOTIF "RPM" "$list" || true ;}
			[ "$notif_email" = "yes" ] && { SEND-EMAIL "RPM" "$list" || true ;}
		fi
	else
		CECHO "[INFO]" "$vert" -n && echo -e " ${gras}Votre système ($host) est déjà à jour.${reinit}"
	fi
	return 0
}
################################################################################################################################
GESTION-FPK() {
	listtmpFP="/tmp/listFP.tmp"
	if EXISTS flatpak; then
		INIT-LOGFP || true
		echo
		PRINTBANNER-CENTERED "GESTION DES FLATPAKs" "." "$cyan"
		# Check for available updates
		CECHO "[INFO]" "$vert" -n && echo -n " Vérification des paquets disponibles "
		FPK_CHECKUPDCMD
		#cat "$listtmpFP" | awk '{printf "%-45s %-7s\n", $2, $3}' | sed 's/^/  /' > "$listFP" || true
		#awk '{printf "%-45s %-7s\n", $2, $3}' "$listtmpFP" | sed 's/^/  /' > "$listFP" || true
		awk '{printf "  %-45s %-7s\n", $2, $3}' "$listtmpFP" > "$listFP" || true
		rm -f "$listtmpFP"
		unset listtmpFP
		# Check for verification errors
		if [ -s "$logerrorFP" ]; then
			CECHO "[ERR.]" "$rouge" -n && echo " La vérification a échoué :"
			$bat "$logerrorFP" || true
			echo
		else
			if [ -s "$listFP" ]; then # fichier non vide donc il y a des maj
				# Display logs based on `silent` mode
				if [ -n "$silent" ]; then
					$bat "$listFP" || true
				fi
				if [ "$changelog" = "--changelogs" ]; then
					FPK_CHANGELOG || true
				fi
				if [ -z "$checkonly" ]; then
					# Download and install updates
					CECHO "[INFO]" "$vert" -n && echo -n " Mise à jour des paquets "
					FPK_UPDCMD
					# Check for errors during the update process
					if [ -s "$logerrorFP" ]; then
						CECHO "[ERR.]" "$rouge" -n && echo " Le téléchargement a échoué : "
						$bat "$logerrorFP" || true
					fi
				else  # Mode checkonly
					CECHO "[INFO]" "$vert" -n && echo " Des mises à jour sont disponibles."
					[ "$notif" = "yes" ] && { GESTION-NOTIF "FLATPAK" "$listFP" || true ;}
					[ "$notif_email" = "yes" ] && { SEND-EMAIL "FLATPAK" "$listFP" || true ;}
				fi
			else
				CECHO "[INFO]" "$vert" -n && echo -e " ${gras}Votre système ($host) est déjà à jour.${reinit}"
			fi
		fi
	else
		echo
		CECHO "[INFO]" "$vert" -n && echo -e " La commande ${gras}${bleu}flatpak${reinit} n'est pas détectée sur ce système."
		CECHO "[INFO]" "$vert" -n && echo -e " Vous pouvez l'installer avec la commande : ${gras}${bleu}sudo dnf install flatpak${reinit}."
		CECHO "[INFO]" "$vert" -n && echo " En attendant, la gestion des FLATPAKs est désactivée."
	fi
	return 0
}
