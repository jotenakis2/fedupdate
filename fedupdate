}

################################################# Cargo COMMANDS #####################################################
RUST_CHECKUPDCMD() {
    if [[ "${silent}" = "yes" ]]; then
        { trap STOP-SPINNER EXIT && START-SPINNER; }
        cargo install-update -l >"${listtmpRust}" 2>>"${logerrorRust}" || true
        { STOP-SPINNER && echo "terminée."; }
    else
        # en mode normal, j'affiche tout en gris, je stocke les erreurs et la liste des updates (nettoyée)")
        echo -e "${gris}"
        cargo install-update -l > >(tee "${listtmpRust}") 2> >(tee -a "${logerrorRust}" >&2) || true
        echo -ne "${reset}"
    fi
    cat "${listtmpRust}" >>"${logRust}"
    awk -i inplace 'tolower($NF) ~ /^(yes|no)$/ && tolower($NF) != "no" {print $1}' "${listtmpRust}" # liste des fichiers à mettre à jour
    return 0
}
#-------------------------------------------------------------------------------------------
RUST_UPDCMD() {
    if EXISTS cargo-binstall; then
        local crate
        if [[ "${silent}" = "yes" ]]; then
            { trap STOP-SPINNER EXIT && START-SPINNER; }
            while read -r crate ; do
                cargo binstall "${crate}" -y >>"${logRust}" 2>>"${logerrorRust}" || true
            done < "${listRust}"
            { STOP-SPINNER && echo "terminée."; }
        else
            echo -e "${gris}"
            while read -r crate ; do
                cargo binstall "${crate}" -y > >(tee -a "${logRust}") 2> >(tee -a "${logerrorRust}" >&2) || true
            done < "${listRust}"
            echo -ne "${reset}"
        fi
    else
        if [[ "${silent}" = "yes" ]]; then
            { trap STOP-SPINNER EXIT && START-SPINNER; }
            cargo install-update -a >>"${logRust}" 2>>"${logerrorRust}" || true
            { STOP-SPINNER && echo "terminée."; }
        else
            echo -e "${gris}"
            cargo install-update -a > >(tee -a "${logRust}") 2> >(tee -a "${logerrorRust}" >&2) || true
            echo -ne "${reset}"
        fi
    fi
    return 0
}
