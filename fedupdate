################################################################################################################################
CHECK_DNF_VERSION() {
    local version_info=""
    version_info=$(${dnf} --version 2>/dev/null || echo "unknown")
    if echo "${version_info}" | grep -q "^dnf5"; then
        echo "dnf5"
        return 0
    elif echo "${version_info}" | grep -q "4\."; then
        echo "dnf4"
        return 0
    elif echo "${version_info}" | grep -q "^dnf4"; then
        echo "dnf4"
        return 0
    else
        echo "Unable to determine DNF version." >>"${bigerror}"
        return 1
    fi
}
