################################################################################################################################
GESTION-NOTIF() {
	local type="$1"
	local liste="$2"
	local message
	local icon
	local messagelong
	local tmp="/tmp/file.tmp"
	declare -i attempt=0
	declare -i max_attempts=9
	icon="/usr/share/swcatalog/icons/fedora/128x128/org.mageia.dnfdragora.png"
	message="ExĂŠcutez le programme $scriptfullname pour mettre Ă  jour :"
	# pour plus de lisibilitĂŠ finale
	# j'extrait la 1Ă¨re colonne
	# je nettoie les aarch64, les noaarch, les org.,
	# je trie, je supprime les doublons, et je mets dans un fichier temporaire.
	awk '{print $1}' "$liste" | sort -u | sed -E 's/\.aarch64$//; s/\.noarch$//; s/^org\.//'  > "$tmp"
	# je remplace les sauts de lignes par une virgule suivie de 3 espaces et j'enlĂ¨ve la toute derniĂ¨re virgule.
	# car notify-send ne gĂ¨re pas l'affichage d'une colonne.
	# je met le rĂŠsultat dans la variable messagelong qui sera affichĂŠe par notify-send
	messagelong=$(tr '\n' ',' < "$tmp" | sed 's/,/,   /g' | sed 's/[[:space:]]*,[[:space:]]*$/ /')
	rm -f "$tmp" 2>/dev/null
	# Attendre que D-Bus notif soit prĂŞt (9 tours max)
	while ! dbus-send --session --dest=org.freedesktop.notifications --type=method_call \
			/org/freedesktop/notifications org.freedesktop.notifications.GetCapabilities >/dev/null 2>&1; do
		attempt=$((attempt + 1))
		if [ $attempt -ge $max_attempts ]; then
			DATE-ET-HEURE >> "$bigerror"
			echo "Avertissement : D-Bus n'est toujours pas prĂŞt aprĂ¨s $attempt tentatives. Continuation du script." >> "$bigerror"
			break  # Sortie de la boucle et continuation du script
		fi
		sleep 5
	done
	notify-send -i "$icon" -u critical --app-name "Mises Ă  jour systĂ¨me ($type)" "$message" "$messagelong"
	return 0
}
