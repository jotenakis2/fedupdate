END() {
    echo
    FINAL-LOGS
    for fiche in "${logerrorFPtmp}" "${logerrorRusttmp}" "${logerrortmp}" "${logtmp}" "${logFPtmp}" "${logRusttmp}" "${bigerrortmp}" "${biglogtmp}"; do
        if [[ -e "${fiche}" ]]; then
            mv -f "${fiche}" "${datadir}"
        fi
    done
    CLEAR-LOGS
    # Display available logs
    PRINTBANNER-CENTERED "" "." "${cyan}"
    if [[ "${islogrotate}" = "yes" ]]; then
        CECHO "[INFO]" "${vert}" -n
        echo " Rotation des logs."
    fi
    case ${nblog} in
        0) echo -n ;;
        1)
            CECHO "[INFO]" "${vert}" -n
            echo " Log : ${listlog}"
            ;;
        *)
            CECHO "[INFO]" "${vert}" -n
            echo " Logs : ${listlog}"
            ;;
    esac
    # Final message
    local hrf
    hrf="$(DATE-ET-HEURE)"
    CECHO "[INFO]" "${vert}" -n
    echo -e " Script terminé avec $1 à ${hrf}."
    PRINTBANNER-CENTERED "" "*" "${gras}${bleu}"
