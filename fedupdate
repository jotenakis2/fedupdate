################################################################################################################################
START-SPINNER() {
if [ "$terminal" != "dumb" ]; then
    set +m
    tput civis
    echo -ne "en cours...  ${rouge})"
    local frames=('â ' 'â ' 'â š' 'â ¸' 'â ź' 'â ´' 'â Ś' 'â §' 'â ' 'â ')
    local index=""
    { while : ; do for index in "${frames[@]}" ; do echo -en "\b$index" ; sleep 0.05 ; done ; done & } 2>/dev/null
    spinner_pid=$!
    return 0
fi
}
################################################################################################################################
STOP-SPINNER() {
if [ "$terminal" != "dumb" ]; then
	{ kill -9 $spinner_pid && wait; } 2>/dev/null
    set -m
	echo -en "\b\b"
	tput cvvis
	echo -ne "$reinit"
	return 0
fi
}
