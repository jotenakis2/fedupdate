################################################################################################################################
CLEAR-LOGS() {
	local fiche
	nblog=0
	listlog=""
	rm -f "$list" "$listFP"
	if [ "$limitlog" = "yes" ]; then
		[ "$existupdateFP" = ""  ] && rm -f "$logFP"
		[ "$existupdateRPM" = "" ] && rm -f "$log"
	fi
	for fiche in "$logerrorFP" "$logerror" "$log" "$logFP" "$bigerror" "$biglog"; do
		if [ "$nolog" = "yes" ]; then
			rm -f "$fiche"
		else
			if [ ! -s "$fiche" ]; then # suppression si vide
				rm -f "$fiche"
			else
				# on compte le nb de log, on ajoute la date ; et on les concatène pour afficher
				if [ "$fiche" = "$logerror" ] && [ "$error" = "yes" ]; then
					nblog=$(( nblog + 1 ))
					echo >> "$fiche"
					DATE-ET-HEURE >> "$fiche"
					listlog="${listlog}${fiche} "
				elif [ "$fiche" != "$logerror" ]; then
					nblog=$(( nblog + 1 ))
					echo >> "$fiche"
					DATE-ET-HEURE >> "$fiche"
					listlog="${listlog}${fiche} "
				fi
			fi
		fi
	done
}
################################################################################################################################
THE-END() {
	echo
	FINAL-LOGS || true
	for fiche in "$logerrorFPtmp" "$logerrortmp" "$logtmp" "$logFPtmp" "$bigerrortmp" "$biglogtmp"; do
		if [ -e "$fiche" ]; then
			mv -f "$fiche" "$datadir"
		fi
	done
	CLEAR-LOGS
	# Display available logs
	PRINTBANNER-CENTERED "" "." "$cyan"
	if [ "$islogrotate" = "yes" ]; then
		CECHO "[INFO]" "$vert" -n && echo " Rotation des logs."
	fi
	case $nblog in
		0) echo -n ;;
		1) CECHO "[INFO]" "$vert" -n ; echo " Log : $listlog" || true ;;
		*) CECHO "[INFO]" "$vert" -n ; echo " Logs : $listlog" || true ;;
	esac
	# Final message
	CECHO "[INFO]" "$vert" -n && echo -e " Script terminé avec $1 à $(DATE-ET-HEURE)."
	PRINTBANNER-CENTERED "" "*" "$gras$bleu"
	export LANG="$LANG0"
	return 0
}
################################################################################################################################
ERROR-ARGS() {
	CECHO "[ERR.]" "$rouge" -n && echo -e " Argument(s) inconnu(s) : ${rouge}$cmdline${reinit}"
	USAGE || true
	errorargs="yes"
	THE-END "des erreurs" || true
	exit 1
}
################################################################################################################################
LOAD-CONFIGRC() {
# On charge le fichier de configuration ou on s arrete s'il n'existe pas (si le script est lancé en auto, sinon on continue)
	if [ -f "$config" ]; then
		# shellcheck source=/dev/null
		source "$config" || true
	else
		if [ "$terminal" = "dumb" ]; then
			DATE-ET-HEURE >> "$bigerror" || true
			CECHO "[WARN]" "$jaune" -n && { echo " Fichier de conf introuvable" | tee -a "$bigerror" || true ;}
			CECHO "[INFO]" "$vert" -n && { echo " Veuillez exécuter la commande suivante pour créer le fichier de configuration :" | tee -a "$bigerror" || true ;}
			echo -e "	${gras}${bleu}$scriptfullname -C${reinit}" | tee -a "$bigerror" || true
			THE-END "des erreurs" | tee -a "$bigerror" || true
			exit 1
		fi
	fi
return 0
}
################################################################################################################################
DELETE-LOG() {
	CECHO "[INFO]" "$vert" -n && echo " Suppression de tous les logs."
	rm -f "$datadir"/*.log*
}
################################################################################################################################
GESTION-ARGS() {
	local options
	local arg
	# gestion de la ligne de commande avec arguments courts ou longs
	options=$(getopt -o 'svhcmMnFR0CdBbpL45ulD' \
	-l 'silent,verbose,help,checkonly,notif_mail,nomail,notify,noflatpak,norpm,nolog,checkdeps,directrpms,nocacheupd,forcecacheupd,poweroff, \
	changelog,forcednf4,forcednf5,distrupgrade,limitlog,deletelog' -- "$@" 2>/dev/null) || ERROR-ARGS
	eval set -- "$options"
	while true; do
		case "$1" in
			-s|--silent)        silent="yes"				; shift ;;
			-v|--verbose)       verbose="yes"				; shift ;;
			-h|--help)          help="yes"					; shift ;;
			-c|--checkonly)	    checkonly="yes"				; shift ;;
			-m|--notif_mail)    notif_email="yes"			; shift ;;
			-M|--nomail)        nomail="yes"				; shift ;;
			-n|--notify)        notif="yes"					; shift ;;
			-F|--noflatpak)     noflatpak="yes"				; shift ;;
			-R|--norpm)         norpm="yes"					; shift ;;
			-0|--nolog)         nolog="yes"					; shift ;;
			-C|--checkdeps)     checkdeps="yes"				; shift ;;
			-d|--directrpms)    directrpms="yes"			; shift ;;
			-B|--nocacheupd)    nocacheupd="yes"			; shift ;;
			-b|--forcecacheupd) forcecacheupd="yes"			; shift ;;
			-p|--poweroff)      poweroff="yes"				; shift ;;
			-L|--changelog)		changelog="yes"				; shift ;;
			-4|--forcednf4)		USE-DNF4					; shift ;;
			-5|--forcednf5)		USE-DNF5					; shift ;;
			-u|--distrupgrade)	distrupgrade="yes"			; shift ;;
			-l|--limitlog)		limitlog="yes"				; shift ;;
			-D|--deletelog)		deletelog="yes"				; shift ;;
			--)                 shift						; break ;; # End of options
			*)                  ERROR-ARGS							;;
		esac
	done
	for arg in "$@"; do
		if [[ "$arg" != -* ]]; then
			ERROR-ARGS
		fi
	done
	# /fin de gestion de la ligne de commande.
	return 0
}
