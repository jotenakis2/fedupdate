################################################################################################################################
INIT-LOGS() {
	datadir="$HOME/.local/share/${scriptname}"
	confdir="$HOME/.config/${scriptname}"
	# Ensure data and config directories exist
	[ ! -d "$datadir" ] && { mkdir -p "$datadir" || true ;}
	[ ! -d "$confdir" ] && { mkdir -p "$confdir" || true ;}
	passwordencrypted="$datadir/.password.enc"
	privatekey="$datadir/.${scriptname}_rsa.pem"
	config="$confdir/config.rc"
	log="${scriptname}-RPM"
	logFP="${scriptname}-Flatpak"
	logerrorFP="${scriptname}-Flatpak.error"
	logerror="${scriptname}-RPM.error"
	bigerror="${scriptname}.error"
	LOG-ROTATE || true
	list="$datadir/RPMs.tmp.list"
	listFP="$datadir/Flatpaks.tmp.list"
	rm -f "$log" "$logFP" "$logerror" "$logerrorFP" "$bigerror" "$list" "$listFP"
	touch "$log" "$logFP" "$logerror" "$logerrorFP" "$bigerror" "$list" "$listFP" || { echo "Echec lors de la création des logs" >&2; exit 1; }
	chmod 640 "$log" "$logFP" "$logerror" "$logerrorFP" "$bigerror" "$list" "$listFP" || { echo "Echec lors de la création des droits" >&2; exit 1; }
}
