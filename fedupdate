################################################################################################################################
MANAGE-ARGS() {
    local options
    local arg
    # gestion de la ligne de commande avec arguments courts ou longs
    options=$(getopt -o 'AsvhcmMnFR0CdBbpPL45ulDiI' \
        -l 'norust,silent,verbose,help,checkonly,notif_mail,nomail,notify,noflatpak,norpm,nolog,checkdeps,directrpms,nocacheupd, \
	forcecacheupd,poweroff,nopoweroff,changelog,forcednf4,forcednf5,distrupgrade,limitlog,deletelog,interactive,nointeractive' -- "$@" 2>/dev/null) ||
        ERROR-ARGS
    eval set -- "${options}"
    while true; do
        case "$1" in
        -s | --silent)
            silent="yes"
            shift
            ;;
        -v | --verbose)
            verbose="yes"
            shift
            ;;
        -h | --help)
            help="yes"
            shift
            ;;
        -c | --checkonly)
            checkonly="yes"
            shift
            ;;
        -m | --notif_mail)
            notif_email="yes"
            shift
            ;;
        -M | --nomail)
            nomail="yes"
            shift
            ;;
        -n | --notify)
            notif="yes"
            shift
            ;;
        -F | --noflatpak)
            noflatpak="yes"
            shift
            ;;
        -R | --norpm)
            norpm="yes"
            shift
            ;;
        -0 | --nolog)
            nolog="yes"
            shift
            ;;
        -C | --checkdeps)
            checkdeps="yes"
            shift
            ;;
        -d | --directrpms)
            directrpms="yes"
            shift
            ;;
        -B | --nocacheupd)
            nocacheupd="yes"
            shift
            ;;
        -b | --forcecacheupd)
            forcecacheupd="yes"
            shift
            ;;
        -p | --poweroff)
            poweroff="yes"
            shift
            ;;
        -P | --nopoweroff)
            nopoweroff="yes"
            shift
            ;;
        -L | --changelog)
            changelog="yes"
            shift
            ;;
        -4 | --forcednf4)
            USE-DNF4
            shift
            ;;
        -5 | --forcednf5)
            USE-DNF5
            shift
            ;;
        -u | --distrupgrade)
            distrupgrade="yes"
            shift
            ;;
        -l | --limitlog)
            limitlog="yes"
            shift
            ;;
        -D | --deletelog)
            deletelog="yes"
            shift
            ;;
        -A | --norust)
            norust="yes"
            shift
            ;;
        -i | --interactive)
            interactive="yes"
            shift
            ;;
        -I | --nointeractive)
            forcenointeractive="yes"
            shift
            ;;
        --)
            shift
            break
            ;; # End of options
        *) ERROR-ARGS ;;
        esac
    done
    for arg in "$@"; do
        if [[ "${arg}" != -* ]]; then
            ERROR-ARGS
        fi
    done
    # /fin de gestion de la ligne de commande.
    return 0
}
