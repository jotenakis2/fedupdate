################################################################################################################################
PRINTBANNER-CENTERED() {
    local msg="${1}"
    local fillertype="${2}"
    local color="${3}"
    [[ $# == 0 ]] && return 1

    declare -i term_cols # Terminal width
    if [[ "${terminal}" = "dumb" ]]; then
        term_cols=135
    else
        term_cols="$(tput cols)" || return 1
        echo -e -n "${color}"
    fi

    declare -i str_len="${#msg}" # Length of $msg
    [[ ${str_len} -ge ${term_cols} ]] && {
        echo "${msg}"
        return 0
    }

    declare -i filler_len="$(((term_cols - str_len) / 2))"
    local ch="${fillertype:0:1}"
    local filler=""
    for ((i = 0; i < filler_len; i++)); do
        filler="${filler}${ch}"
    done

    printf "%s%s%s" "${filler}" "${msg}" "${filler}"
    [[ $(((term_cols - str_len) % 2)) -ne 0 ]] && printf "%s" "${ch}"
    printf "\n"
    echo -ne "${reset}"
    return 0
}

################################################################################################################################
CLEAR() { # fonction pour effacer le terminal en préservant le scrollback.
    local h
    h="$(tput lines 2>/dev/null)" || h=0

    if [[ "${h}" -gt 1 ]]; then
        until [[ "${h}" -le 1 ]]; do
            printf '\n'
            h=$((h - 1))
        done
    fi
    command clear -x || true
    return 0
}

################################################################################################################################
ASK-YESNO() {
    #   1. Messsage introductif
    #   2. Couleur du type de message introduction : par exemple vert pour [INFO]
    #   3. Question à laquelle l utilisateur devra répondre
    #   4. Couleur du type accompagnant la question ([ACT.] est le type forcé, pour ACTION).
    #   5. Type du message introductif : par exemple [INFO]
    # ===>   la fonction retourne le code 0 si la réponse est oui, 1 si non.
    if [[ "${terminal}" != "dumb" ]]; then # le script n'est pas lancé en arrière plan
        local message="${1}"
        local color1="${2}"
        local question="${3}"
        local color2="${4}"
        local type="${5}"
        local input_string="NA"
        local colorinteractive=""

        CECHO "${type}" "${color1}" -n
        if [[ "${interactive}" = "yes" ]]; then
            colorinteractive="${surligne}" # en mode interactif je surligne le message et la question
        fi
        echo -e "${colorinteractive}${message}${reset}"

        while [[ "${input_string}" != "oui" ]] && [[ "${input_string}" != "o" ]] && [[ "${input_string}" != "" ]] && [[ "${input_string}" != "non" ]] && [[ "${input_string}" != "n" ]]; do
            CECHO "[ACT.]" "${color2}" -n
            echo -en "${colorinteractive}${question} (O/n) ?${reset}"
            IFS= read -r input_string || input_string="non" # fallback in case of read error
            input_string="${input_string,,}"                # je passe tout en minuscules
        done

        if [[ "${input_string}" = "oui" ]] || [[ "${input_string}" = "o" ]] || [[ "${input_string}" = "" ]]; then # j'accepte oui, OUI, o, O, ... choix par défaut = oui
            return 0
        elif [[ "${input_string}" = "non" ]] || [[ "${input_string}" = "n" ]]; then # j'accepte non, NON, n, N, ...
            return 1
        fi
    else # le script est lancé en arrière plan, la réponse par défaut est non.
        return 1
    fi
}
