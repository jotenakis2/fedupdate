EXISTS() {
	unalias "$1" >/dev/null 2>&1 || true
	command -v "$1" >/dev/null 2>&1
}
################################################################################################################################
CECHO() { # script to write something to stdout in colors
   	local message=$1
   	local color=$2
   	local nonewline=$3
   	if [ "$terminal" != "dumb" ]; then
  		echo -e "$nonewline" "$color$message$reinit" || true
   	else
  		echo "$nonewline" "$message" || true
   	fi
   	return 0
}
