	[ "$noflatpak" = "yes" ] && echo -e " $modeF (${vert}-F${reinit})." >> "$biglog"
	[ "$norpm" = "yes" ] && echo -e " $modeR (${vert}-R${reinit})." >> "$biglog"
	[ "$nolog" = "yes" ] && echo -e " $mode0 (${vert}-0${reinit})." >> "$biglog"
	[ "$limitlog" = "yes" ] && echo -e " $modeLP (${vert}-l${reinit})." >> "$biglog"
	[ "$directrpms" = "yes" ] && echo -e " $modeD (${vert}-d${reinit})." >> "$biglog"
	[ "$nocacheupd" = "yes" ] && echo -e " $modeB (${vert}-B${reinit})." >> "$biglog"
	[ "$forcecacheupd" = "yes" ] && echo -e " $modeBB (${vert}-b${reinit})." >> "$biglog"
	[ "$poweroff" = "yes" ] && echo -e " $modeP (${vert}-p${reinit})." >> "$biglog"
	[ "$changelog" = "yes" ] && echo -e " $modeCL (${vert}-L${reinit})." >> "$biglog"
	[ "$distrupgrade" = "yes" ] && echo -e " $modeU (${vert}-u${reinit})." >> "$biglog"
	[ "$checkonly" = "yes" ] && echo -e " $modeC (${vert}-c${reinit})." >> "$biglog"
	[ "$deletelog" = "yes" ] && echo -e " ${jaune}mode \"suppression des logs\"${reinit} (${vert}-D${reinit})." >> "$biglog"
	[ "$forcednf4" = "yes" ] && { echo -e " $mode4 (${vert}-4${reinit})." >> "$biglog" ; dnf="/usr/bin/dnf4" ;}
	[ "$forcednf5" = "yes" ] && { echo -e " $mode5 (${vert}-5${reinit})." >> "$biglog" ; dnf="/usr/bin/dnf5" ;}
#----------------------------------

# Gestion des incompatibilités de modes
	if [ "$silent" = "yes" ] && [ "$verbose" = "yes" ]; then
		echo -e " Le $modeS (${vert}-s${reinit}) est incompatible avec le $modeV (${vert}-v${reinit})." >> "$biglog"
		echo -e " On force donc le $modeV (${vert}-v${reinit})." >> "$biglog"
		silent=""
	fi
	if [ "$silent" = "yes" ] && [ "$distrupgrade" = "yes" ]; then
		echo -e " En $modeU (${vert}-u${reinit}), on désactive le $modeS (${vert}-s${reinit})." >> "$biglog"
		silent=""
	fi
	if [ "$forcednf4" = "yes" ] && [ "$forcednf5" = "yes" ]; then
		echo -e " Les modes ${gras}${bleu}dnf4${reinit} et ${gras}${bleu}dnf5${reinit} ne peuvent être utilisés en même temps." >> "$biglog"
		echo -e " On utilise ${gras}${bleu}/usr/bin/dnf${reinit}." >> "$biglog"
		dnf="/usr/bin/dnf"
		forcednf4=""
		forcednf5=""
	fi
	if { [ "$forcednf4" = "yes" ] || [ "$forcednf5" = "yes" ]; } && [ "$distrupgrade" = "yes" ]; then
		echo -e " Les modes forcés ${gras}${bleu}dnf4${reinit} et ${gras}${bleu}dnf5${reinit} ne sont pas compatibles avec le $modeU (${vert}-u${reinit})." >> "$biglog"
		echo -e " On utilise ${gras}${bleu}/usr/bin/dnf${reinit}." >> "$biglog"
		dnf="/usr/bin/dnf"
		forcednf4=""
		forcednf5=""
	fi
	if [ "$distrupgrade" = "yes" ] && [ "$nocacheupd" = "yes" ]; then
		echo -e " Le $modeU (${vert}-u${reinit}) est incompatible avec le $modeB (${vert}-B${reinit})." >> "$biglog"
		echo -e " On ignore donc le $modeB (${vert}-B${reinit})." >> "$biglog"
		nocacheupd=""
	fi
	if [ "$distrupgrade" = "yes" ] && [ "$norpm" = "yes" ]; then
		echo -e " Le $modeU (${vert}-u${reinit}) est incompatible avec le $modeR (${vert}-R${reinit})." >> "$biglog"
		echo -e " On ignore donc le $modeR (${vert}-R${reinit})." >> "$biglog"
		norpm=""
	fi
	if [ "$nocacheupd" = "yes" ] && [ "$forcecacheupd" = "yes" ]; then
		echo -e " Le $modeB (${vert}-B${reinit}) est incompatible avec le $modeBB (${vert}-b${reinit})." >> "$biglog"
		echo -e " On force donc le $modeBB (${vert}-b${reinit})." >> "$biglog"
		nocacheupd=""
	fi
#----------------------------------

# Contrôles du mode email (verif adresse email existe et commande mail est installée)
	if [ "$notif_email" = "yes" ]; then
		if [ -z "$email" ]; then
			DATE-ET-HEURE >> "$bigerror" || true
			CECHO "[WARN]" "$jaune" -n && { echo " Aucune adresse email trouvée." | tee -a "$bigerror" || true ;}
			CECHO "[INFO]" "$vert" -n && { echo " Veuillez exécuter la commande suivante pour créer le fichier de configuration :" | tee -a "$bigerror" || true ;}
			echo -e "	${gras}${bleu}$scriptfullname -C${reinit}" | tee -a "$bigerror" || true
			THE-END "des erreurs" | tee -a "$bigerror" || true
			exit 1
		else
			echo -e " e-mail : ${bleu}$email${reinit}." >> "$biglog"
		fi
		if ! EXISTS mail; then
			DATE-ET-HEURE >> "$bigerror" || true
			CECHO "[ERR.]" "$rouge" -n && { echo -e " La commande ${gras}${bleu}mail${reinit} n'est pas disponible sur votre système." | tee -a "$bigerror" || true ;}
			CECHO "[INFO]" "$vert" -n && { echo -e " Vous pouvez l'installer avec la commande : ${gras}${bleu}sudo dnf install s-nail${reinit}." | tee -a "$bigerror" || true ;}
			CECHO "[WARN]" "$jaune" -n && { echo -e " Vous devez aussi installer et configurer un \"Mail Transport Agent\", par exemple ${gras}${bleu}msmtp${reinit} avec la commande ${gras}${bleu}sudo dnf install msmtp${reinit}." | tee -a "$bigerror" || true ;}
		fi
	fi
#----------------------------------

# Contrôle du mode vérification (incompatibilités avec et sans le mode -c)
	if [ "$checkonly" = "yes" ]; then
		if [ "$distrupgrade" = "yes" ]; then
			echo -e " Le $modeU (${vert}-u${reinit}) est incompatible avec le $modeC (${vert}-c${reinit})." >> "$biglog"
			echo -e " On ignore donc le $modeU (${vert}-u${reinit})." >> "$biglog"
			distrupgrade=""
		fi
		if [ "$notif_email" = "yes" ]; then
			echo -e " $modeM (${vert}-m${reinit})." >> "$biglog"
			if [ "$nomail" = "yes" ]; then
				echo -e " Le $modeM (${vert}-m${reinit}) est incompatible avec le $modeMM (${vert}-M${reinit})." >> "$biglog"
				echo -e " On ignore donc le $modeM (${vert}-m${reinit})." >> "$biglog"
				notif_email=""
			fi
		fi
		if [ "$notif" = "yes" ]; then
			echo -e " $modeN (${vert}-n${reinit})." >> "$biglog"
		fi
	else
		if [ "$notif_email" = "yes" ]; then
			echo -e " $modeM (${vert}-m${reinit}) ignoré car le $modeC (${vert}-c${reinit}) n'est pas activé." >> "$biglog"
			notif_email=""
		fi
		if [ "$notif" = "yes" ]; then
			echo -e " $modeN (${vert}-n${reinit}) ignoré car le $modeC (${vert}-c${reinit}) n'est pas activé." >> "$biglog"
			notif=""
		fi
	fi
#----------------------------------

# Finalisation
	CECHO "[INFO]" "$vert" -n && echo -en " Options retenues (arguments longs) : ${gras}${vert}" | tee -a "$biglog"
	for opts in silent verbose help checkonly notif_email nomail notif noflatpak norpm nolog checkdeps directrpms nocacheupd \
				forcecacheupd poweroff changelog forcednf4 forcednf5 distrupgrade limitlog deletelog ; do
	    if [ "${!opts}" = "yes" ]; then
       	echo -n "--$opts " | tee -a "$biglog"
       fi
   done
	echo -e "${reinit}" | tee -a "$biglog"
	dnfver="$(CHECK_DNF_VERSION || echo "unknown")"
	[ "$norpm" = "" ] && INIT-LOGRPM
#----------------------------------

return 0
}
################################################################################################################################
LOG-ROTATE() {
    declare -i max_logs=10
    local -A log_prefixes=(
        [log]="$log"
        [logFP]="$logFP"
        [logerror]="$logerror"
        [logerrorFP]="$logerrorFP"
        [bigerror]="$bigerror"
        [biglog]="$biglog"
    )
    for key in "${!log_prefixes[@]}"; do
        local prefix="${log_prefixes[$key]}"
        # Supprime le fichier de log le plus ancien s'il existe (par exemple, .log.(max_logs-1))
        local oldest_log="$datadir/${prefix}.log.$((max_logs - 1))"
        if [[ -e "$oldest_log" ]]; then
            rm -f "$oldest_log" || { echo "Échec lors de la suppression de $oldest_log" >&2; return 1; }
        fi
        # Décale les fichiers de log existants d'un suffixe, en commençant par le suffixe le plus élevé jusqu'à .log.1
        for (( i=max_logs-2; i>=1; i-- )); do
            local old_log="$datadir/${prefix}.log.$i"
            local new_log="$datadir/${prefix}.log.$((i + 1))"
            if [[ -e "$old_log" ]]; then
                mv "$old_log" "$new_log" || { echo "Échec lors du renommage de $old_log en $new_log" >&2; return 1; }
            fi
        done
        # Renomme le fichier .log actuel en .log.1 s'il existe
        if [[ -e "$datadir/${prefix}.log" ]]; then
            mv "$datadir/${prefix}.log" "$datadir/${prefix}.log.1" || { echo "Échec lors du renommage de ${prefix}.log en ${prefix}.log.1" >&2; return 1; }
        fi
        # Met à jour la variable globale pour qu'elle pointe vers le fichier de log actuel, qui est toujours .log
        eval "$key=\"$datadir/${prefix}.log\""
    done
}
################################################################################################################################
INIT-LOGFP() {
	{	DATE-ET-HEURE ;
		echo "$scriptfullname $cmdline (v$ver)" ;
