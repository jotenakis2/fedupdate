################################################################################################################################
FINAL-LOGS() {
	islogrotate=""
	local existupdate=""
	if [ "$existupdateRPM" = "yes" ] || [ "$existupdateFP" = "yes" ]; then # pour définir s'il y a eu des maj
		existupdate="yes"
	fi
	if [ "$limitlog" = "yes" ] && [ "$existupdate" = "yes" ] ; then # on tourne les log en cas de mode limitlog ON avec des maj, si le mode nolog est OFF
		[ "$nolog" = "" ] && islogrotate="yes"
	fi
	if [ "$limitlog" = "yes" ] && [ "$existupdate" = "" ] ; then # on force la suppression des logs en mode limitlog ON sans maj.
		nolog="yes" # forçage suppression du fichier
	fi
	if [ "$limitlog" = "" ] ; then # si les modes limitlog et nolog ne sont pas activés, on tourne les logs
		[ "$nolog" = "" ] && islogrotate="yes"
	fi
	for fiche in "$logerrorFPtmp" "$logerrortmp" "$logtmp" "$logFPtmp" "$bigerrortmp" "$biglogtmp"; do
		if [ "$nolog" = "yes" ]; then
			rm -f "$fiche"
		else
			if [ ! -s "$fiche" ]; then # suppression si vide
				rm -f "$fiche"
			fi
		fi
	done
    [ "$errorargs" = "yes" ] && islogrotate=""
	if [ "$islogrotate" = "yes" ] ; then
		log="${scriptname}-RPM"
		logFP="${scriptname}-Flatpak"
		logerrorFP="${scriptname}-Flatpak.error"
		logerror="${scriptname}-RPM.error"
		bigerror="${scriptname}.error"
		biglog="${scriptname}"
		LOG-ROTATE || true
		rm -f "$log" "$logFP" "$logerror" "$logerrorFP" "$bigerror" "$list" "$listFP" "$biglog"
		touch "$log" "$logFP" "$logerror" "$logerrorFP" "$bigerror" "$list" "$listFP" "$biglog" || { echo "Echec lors de la création des logs" >&2; exit 1; }
		chmod 640 "$log" "$logFP" "$logerror" "$logerrorFP" "$bigerror" "$list" "$listFP" "$biglog" || { echo "Echec lors de la création des droits" >&2; exit 1; }
	fi
}
