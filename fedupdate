DNF_UPGRADECMD() { # mise à niveau
	SUDOPASS
	local -i TARGET
	TARGET=$1
	echo -ne "$gris"
	if [[ "$dnfver" == "dnf4" ]]; then
		# shellcheck disable=SC2024
		sudo $dnf -y system-upgrade download --allowerasing --setopt=module_platform_id=platform:f$TARGET --releasever=$TARGET > >(tee -a "$log") 2> >(tee -a "$logerror" >&2) || true
	else
		# shellcheck disable=SC2024
		sudo $dnf -y system-upgrade download --setopt=module_platform_id=platform:f$TARGET --releasever=$TARGET > >(tee -a "$log") 2> >(tee -a "$logerror" >&2) || true
	fi
	echo -ne "$reinit"
}
#-------------------------------------------------------------------------------------------
DNF_CHECK_OFFLINE_UPGRADE_READY() {
    SUDOPASS
    local dnf_file=""
   	if [[ "$dnfver" == "dnf4" ]]; then
    	dnf_file="/var/lib/dnf/system-upgrade/system-upgrade-transaction.json"
    else
    	dnf_file="/usr/lib/sysimage/libdnf5/offline/transaction.json"
    fi
    if sudo ls "$dnf_file" &>/dev/null; then # je teste la présence du fichier en root car $USER n'a pas les droits
        return 0
    else
    	return 1
    fi
}
