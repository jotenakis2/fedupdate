################################################################################################################################
GESTION-NOTIF() {
	local type
	type="$1"
	local liste
	liste="$2"
	local message
	local icon
	local messagelong
	local tmp
	tmp="$HOME/.cache/file.tmp"
	declare -i attempt=0
	declare -i max_attempts=9
	icon="/usr/share/swcatalog/icons/fedora/128x128/org.mageia.dnfdragora.png"
	message="Mises à jour disponibles"
	# Extract and format list for the notification
	awk '{print $1}' "$liste" | sort -u | sed -E 's/\.aarch64$//; s/\.noarch$//; s/^org\.//' > "$tmp" || true
	messagelong="$(tr '\n' ',' < "$tmp" | sed 's/,/,   /g' | sed 's/[[:space:]]*,[[:space:]]*$/ /')" || messagelong="(Liste indisponible)"
	rm -f "$tmp"
	unset "$tmp"
	# Wait for D-Bus notifications to be ready (max 9 attempts)
	while ! dbus-send --session --dest=org.freedesktop.notifications --type=method_call \
			/org/freedesktop/notifications org.freedesktop.notifications.GetCapabilities >/dev/null 2>&1; do
		attempt=$((attempt + 1))
		if [ $attempt -ge $max_attempts ]; then
			DATE-ET-HEURE >> "$bigerror"
			echo "Avertissement : D-Bus n'est toujours pas prêt après $attempt tentatives. Continuation du script." >> "$bigerror" || true
			break  # Exit the loop and continue the script
		fi
		sleep 5 || true
	done
	# Send notification
	notify-send -i "$icon" -u critical --app-name "$scriptname ($type)" "$message" "$messagelong" || true
	return 0
}
