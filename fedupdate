################################################# flatpak COMMANDS ##############################################################
FPK_CHECKUPDCMD() {
	if [ "$silent" = "yes"  ]; then
		# en mode pseudosilencieux je n'affiche rien, je stocke les erreurs et la liste des upd et je met un spinner d'attente
		{ trap STOP-SPINNER EXIT && START-SPINNER; }
			# shellcheck disable=SC2024
			flatpak update >"$listtmpFP" 2>>"$logerrorFP" || true
		{ STOP-SPINNER && echo "terminée."; }
	else
		# en mode normal, j'affiche tout en gris, je stocke les erreurs et la liste des upd (nettoyée)")
		echo -e "$gris"
		# shellcheck disable=SC2024
		flatpak update > >(tee "$listtmpFP") 2> >(tee -a "$logerrorFP" >&2) || true
		echo -ne "$reinit"
	fi
	cat "$listtmpFP" >> "$logFP"
	sed -i '/^[[:space:]]*[0-9]\+\./!d' "$listtmpFP"
	return 0
}
#-------------------------------------------------------------------------------------------
FPK_UPDCMD() {
	if [ "$silent" = "yes"  ]; then
		{ trap STOP-SPINNER EXIT && START-SPINNER; }
			# shellcheck disable=SC2024
			flatpak -y update >>"$logFP" 2>>"$logerrorFP" || true
		{ STOP-SPINNER && echo "terminée."; }
	else
		echo -e "$gris"
		# shellcheck disable=SC2024
		flatpak -y update > >(tee -a "$logFP") 2> >(tee -a "$logerrorFP" >&2) || true
		echo -ne "$reinit"
	fi
	return 0
}
#-------------------------------------------------------------------------------------------
FPK_CHANGELOG() {
	local updates
	local package
	local repo
	updates=$(awk '{print $1}' "$listFP")
	[[ -z "$updates" ]] && return 0
	for package in $updates; do
		# Get repo info; exit with error if the command fails
		repo=$(flatpak info --show-origin "$package") || {
			echo "Echec lors de la récupération du nom du repo de : $package" >&2 >> "$logFP"
			return 1
		}
		# Get log info for the package; exit with error if the command fails
		flatpak remote-info --log "$repo" "$package" || {
			echo "Echec lors de la récupération des infos de : $package" >&2 >> "$logFP"
			return 1
		}
	done
	return 0
}
