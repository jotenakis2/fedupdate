# Reorder the arguments according to getopt's output
eval set -- "$options"
# Parse the options
while true; do
	case "$1" in
		-s|--silent)        silent="yes"				; shift ;;
		-h|--help)          help="yes"					; shift ;;
		-c|--check)	        checkonly="yes"				; shift ;;
		-m|--email)         notif_email="yes"			; shift ;;
		-n|--notify)        notif="yes"					; shift ;;
		-F|--noflatpak)     noflatpak="yes"				; shift ;;
		-R|--norpm)         norpm="yes"					; shift ;;
		-0|--nolog)         nolog="yes"					; shift ;;
		-C|--checkdeps)     checkdeps="yes"				; shift ;;
		-d|--direct)        directrpms="yes"			; shift ;;
		-B|--nocacheupd)    nocacheupd="yes"			; shift ;;
		-p|--poweroff)      poweroff="yes"				; shift ;;
