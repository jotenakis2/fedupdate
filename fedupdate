################################################################################################################################
PASSWORD_INPUT() { # Fonction pour capturer le mot de passe le stocker dans $password et afficher des *
	local password_ref
	password_ref=""
	local char
	# Désactiver l'affichage des caractères
	stty -echo || return 1
	while IFS= read -r -s -n1 char; do
		# on arrête quand la touche ENTREE est pressée
		if [[ -z $char ]]; then
			break
		fi
		# Si la touche backspace est pressée
		if [[ $char == $'\x7f' ]]; then
		    if [[ ${#password_ref} -gt 0 ]]; then
		    password_ref=${password_ref%?}
		    echo -ne "\b \b"
		    fi
		else
		    password_ref+="$char"
		    echo -n '*'
		fi
	done
	password="$password_ref"
	echo
	stty echo || return 1 # Réactiver l'affichage des caractères
	return 0
}
################################################################################################################################
ENCRYPT-PASS() {
	local pubkey="${privatekey}.pub"
	if EXISTS openssl; then
		# Generate private RSA key in PEM format
		if ! openssl genpkey -algorithm RSA -out "$privatekey" -pkeyopt rsa_keygen_bits:4096 >/dev/null 2>&1; then
			CECHO "[ERR.]" "$rouge" -n && echo "Erreur lors de la génération de la clé privée." | tee -a "$bigerror"
			return 1
		fi
		chmod 600 "$privatekey" || true
		# Generate the associated public key in PEM format
		if ! openssl rsa -in "$privatekey" -pubout -out "$pubkey" >/dev/null 2>&1; then
			CECHO "[ERR.]" "$rouge" -n && echo "Erreur lors de la génération de la clé publique." | tee -a "$bigerror"
			return 1
		fi
		# Encrypt password using the public key and store it
		if ! echo -n "$password" | openssl pkeyutl -encrypt -pubin -inkey "$pubkey" -out "$passwordencrypted" >/dev/null 2>&1; then
			CECHO "[ERR.]" "$rouge" -n && echo "Erreur lors du chiffrement du mot de passe." | tee -a "$bigerror"
			return 1
		fi
	else
		CECHO "[ERR.]" "$rouge" -n && echo -e "Le paquet ${gras}${bleu}openssl${reinit} n'est pas installé." | tee -a "$bigerror"
		return 1
	fi
	return 0
}
################################################################################################################################
DECRYPT-PASS() {
	if EXISTS openssl; then
		# Decrypt the password using the private key and store it in the password variable
		if [ -f "$privatekey" ] && [ -f "$passwordencrypted" ]; then
			if ! password=$(openssl pkeyutl -decrypt -inkey "$privatekey" -in "$passwordencrypted" 2>/dev/null); then
				CECHO "[ERR.]" "$rouge" -n && echo "Erreur lors du déchiffrement du mot de passe." | tee -a "$bigerror"
				return 1
			fi
			return 0
		else
			CECHO "[ERR.]" "$rouge" -n && echo "Clé privée ou fichier chiffré manquant." | tee -a "$bigerror"
			return 1
		fi
	else
		CECHO "[ERR.]" "$rouge" -n && echo -e "Le paquet ${gras}${bleu}openssl${reinit} n'est pas installé." | tee -a "$bigerror"
		return 1
	fi
}
################################################################################################################################
CREATE-CONFIG() {
	local msg=$1
	if ASK-YESNO "" "$vert" " Voulez-vous en $msg un maintenant (oui/non) ? " "$magenta" ""; then
		while true; do
			CECHO "[ACT.]" "$magenta" -n && echo -n " Merci de saisir une adresse email valide : "
			IFS= read -r email
			if IS-VALID-EMAIL "$email"; then
				echo "email=\"${email}\"" > "$config" || return 1
				break
			fi
		done
		CECHO "[ACT.]" "$magenta" -n && echo -n " Merci de saisir le mot de passe de l'utilisateur $(whoami) : "
		PASSWORD_INPUT || true
		if EXISTS openssl; then
			if ASK-YESNO "" "$vert" " Voulez-vous stocker le mot de passe ${gras}chiffré${reinit} (oui/non) ? " "$magenta" ""; then
				if ENCRYPT-PASS; then
					CECHO "[INFO]" "$vert" -n && echo -e " Le mot de passe est stocké chiffré dans ${gras}${bleu}$passwordencrypted${reinit}."
					echo "password=\"***EnCrYpTed***\"" >> "$config" || true
				else
					CECHO "[ERR.]" "$rouge" -n && echo " Le chiffrement du mot de passe a échoué."
					CECHO "[INFO]" "$vert" -n && echo " Le mot de passe est donc stocké en clair."
					echo "password=\"${password}\"" >> "$config" || true
					chmod 600 "$config" || true
				fi
			else
				rm -f "$passwordencrypted" "$privatekey" "$privatekey.pub"
				CECHO "[INFO]" "$vert" -n && echo " Le mot de passe est donc stocké en clair."
				echo "password=\"${password}\"" >> "$config" || true
				chmod 600 "$config" || true
			fi
		else #openssl n'est pas installé, on stocke en clair.
			CECHO "[WARN]" "$jaune" -n
			echo -e " Le paquet ${gras}${bleu}openssl${reinit} n'est pas installé, la fonction de stockage de chiffrement n'est pas disponible."
			rm -f "$passwordencrypted" "$privatekey" "$privatekey.pub"
			CECHO "[INFO]" "$vert" -n && echo " Le mot de passe est donc stocké en clair."
			echo "password=\"${password}\"" >> "$config" || true
			chmod 600 "$config" || return 1
		fi
		{	echo;
			echo "# option -4 : (décommentez ci-dessous pour activer)";
			echo "#forcednf4=\"yes\"";
			echo;
			echo "# option -5 : (décommentez ci-dessous pour activer)";
			echo "#forcednf5=\"yes\"";
			echo;
			echo "# option -L : (décommentez ci-dessous pour activer)";
			echo "#changelog=\"yes\"";
			echo;
			echo "# option -s : (décommentez ci-dessous pour activer) INFO : le mode \"-v\" permet de passer outre ce réglage.";
			echo "#silent=\"yes\"";
			echo;
			echo "# option -F : (décommentez ci-dessous pour activer)";
			echo "#noflatpak=\"yes\"";
			echo;
			echo "# option -l : (décommentez ci-dessous pour activer)";
			echo "#limitlog=\"yes\"";
			echo;
			echo "# option -p : (décommentez ci-dessous pour activer)";
			echo "#poweroff=\"yes\"";
			echo;
			echo "# option -m : (décommentez ci-dessous pour activer) INFO : le mode \"-M\" permet de passer outre ce réglage.";
			echo "#notif_email=\"yes\"";
			echo;
			echo "# option -B : (décommentez ci-dessous pour activer) INFO : le mode \"-b\" permet de passer outre ce réglage.";
			echo "#nocacheupd=\"yes\"";
			echo;
		} >> "$config"
		CECHO "[INFO]" "$vert" -n && echo -e " Fichier ${gras}${bleu}$config${reinit} crée :"
		$bat "$config" || return 1
	else
		CECHO "[INFO]" "$vert" -n && echo -e " Création du fichier ${gras}${bleu}$config${reinit} refusée par l'utilisateur."
	fi
	return 0
}
################################################################################################################################
CHECK() { # contrôle des dépendances - peut être explicitement appelé (option -C) et alors il affiche des infos complémentaires
	local cmdmissing="no"
	local cmd=""
	if [ "$checkdeps" = "yes" ]; then # contrôle explicit
		#CECHO "[INFO]" "$vert" -n && echo -e " $modeCC (${vert}-C${reinit})."
		echo
		PRINTBANNER-CENTERED "CONTRÔLE" "." "$cyan"
	fi
	list2check=("bash" "sudo" "awk" "sed" "tput" "find" "notify-send" "dnf" "getopt")
	for cmd in "${list2check[@]}"; do
		if ! EXISTS "$cmd" ; then
			CECHO "[ERR.]" "$rouge" -n && echo " La commande $cmd est manquante, veuillez l'installer."
			cmdmissing="yes"
		fi
	done

	if [ "$checkdeps" = "yes" ] ; then # contrôle explicit
		if [ -f "$config" ]; then
			CECHO "[INFO]" "$vert" -n && echo -e " Contenu du fichier de configuration :"
			$bat "$config" || true
			CREATE-CONFIG "recréer"
		else
			CECHO "[INFO]" "$vert" -n && echo -ne " Fichier de configuration ${gras}${bleu}$config${reinit} manquant."
			CREATE-CONFIG "créer"
		fi
	fi

	if [ "$cmdmissing" = "yes" ] || [ "$checkdeps" = "yes" ] ; then # commande manquante ou contrôle explicit, on précise les paquets
		nolog="yes" # pour éviter une rotation des logs inutiles.
		echo
		if [ "$cmdmissing" = "yes" ]; then
			CECHO "[WARN]" "$jaune" -n && echo -e " Voici la liste des ${gras}${jaune}paquets requis${reinit} pour que ce script fonctionne :"
		else
			CECHO "[INFO]" "$vert" -n && echo -e " Voici la liste des ${gras}${jaune}paquets requis${reinit} pour que ce script fonctionne :"
		fi
		echo -e "	${gras}${bleu}bash${reinit}, ${gras}${bleu}coreutils${reinit}, ${gras}${bleu}dnf${reinit}, ${gras}${bleu}findutils${reinit}, ${gras}${bleu}gawk${reinit}, ${gras}${bleu}libnotify${reinit}, ${gras}${bleu}ncurses${reinit}, ${gras}${bleu}sed${reinit}, ${gras}${bleu}sudo${reinit} et ${gras}${bleu}util-linux${reinit}."
		CECHO "[INFO]" "$vert" -n && echo -e " Voici la liste des ${gras}${jaune}paquets requis trouvés${reinit} sur ${gras}$host${reinit} :"
		SUDOPASS
		sudo $dnf list --installed | grep --color=always -E '^(bash|coreutils|dnf|findutils|gawk|libnotify|ncurses|sed|sudo|util-linux)\.' | awk '{$NF=""; sub(/[[:space:]]+$/, ""); printf "%-50s %s\n", $1, $2}' || true
		echo

		CECHO "[INFO]" "$vert" -n && echo -e " Voici la liste des ${gras}${jaune}paquets optionnels${reinit} :"
		echo -e "	${gras}${bleu}s-nail${reinit}, ${gras}${bleu}msmtp${reinit} (ou ${gras}${bleu}opensmtpd${reinit}), ${gras}${bleu}openssl${reinit} et ${gras}${bleu}flatpak${reinit}."
		CECHO "[INFO]" "$vert" -n && echo -e " Voici la liste des ${gras}${jaune}paquets optionnels trouvés${reinit} sur ${gras}$host${reinit} :"
		SUDOPASS
		sudo $dnf list --installed | grep --color=always -E '^(s-nail|msmtp|opensmtpd|flatpak|openssl)\.' | awk '{$NF=""; sub(/[[:space:]]+$/, ""); printf "%-50s %s\n", $1, $2}' || true

		[ "$cmdmissing" = "yes" ] && { THE-END "des erreurs" || true ; exit 1 ; }
		[ "$checkdeps" = "yes" ] && { THE-END "succès" || true ; exit 0 ; }
	else
		return 0
	fi
}
################################################################################################################################
UNALIAS() { # on desalias les commandes utilisées pour éviter un comportement imprévu
	local cmd=""
	list2check=("unalias" "mkdir" "printf" "mail" "touch" "sleep" "rm" "cat" "bat" "sed" "head" "awk" "echo" "dnf" \
