CECHO() { # script to write something to stdout in colors
    local message=$1
    local color=$2
    local nonewline=$3
    if [[ "${terminal}" != "dumb" ]]; then
        echo -e "${nonewline}" "${color}${message}${reset}"
    else
        echo "${nonewline}" "${message}"
