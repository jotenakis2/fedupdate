	[ "$nocacheupd" = "yes" ] && CECHO "[INFO]" "$vert" -n && echo -e " $modeB (${vert}-B${reinit})."

	if [ -f "$config" ]; then
		# shellcheck source=/dev/null
		source "$config"
	else
		if [ "$terminal" = "dumb" ] ; then
			DATE-ET-HEURE >> "$bigerror"
			echo "mot de passe utilisateur introuvable" | tee -a "$bigerror"
			echo "saisir password=\"mypassword\" dans $config" | tee -a "$bigerror"
			THE-END "des erreurs" | tee -a "$bigerror"
			exit 1
		fi
	fi
	if  [ "$notif_email" = "yes" ]; then # on vĂŠrifie qu'une adresse email est dĂŠfinie et que les paquets requis sont installĂŠs
		if [ -f "$config" ]; then
			CECHO "[INFO]" "$vert" -n && echo -e " Lecture du fichier de configuration (${bleu}$config${reinit})."
			# shellcheck source=/dev/null
			source "$config"  # lecture fichier de conf
		fi
