                    echo -e "${bleu}	sudo dnf offline-upgrade clean${reset}"
                fi
                END "des erreurs"
                exit 1
            fi
        fi
    fi
    if ASK-YESNO " Le script va maintenant redémarrer le système et faire la mise à jour hors-ligne." "${surligne}${vert}" " Êtes-vous d'accord" "${surligne}${magenta}" "[INFO]"; then
