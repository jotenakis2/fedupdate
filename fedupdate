	fi
	[ "$help" = "yes" 	    ] && DISPLAY-HELP
	[ "$checkdeps" = "yes"  ] && { CECHO "[INFO]" "$vert" -n ; echo -e " $modeCC (${vert}-C${reinit})." ; CHECK ;}
	[ "$silent" = "yes"     ] && CECHO "[INFO]" "$vert" -n && echo -e " $modeS (${vert}-s${reinit})."
