		-5|--forcednf5)		USE-DNF5					; shift ;;
		--)                 shift						; break ;; # End of options
		*)                  ERROR-ARGS							;;
	esac
done
# Check for any remaining unrecognized arguments
for arg in "$@"; do
	if [[ "$arg" != -* ]]; then
		ERROR-ARGS
	fi
done
