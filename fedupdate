			THE-END "des erreurs" | tee -a "$bigerror"
			exit 1
		else
			CECHO "[INFO]" "$vert" -n && echo -e " e-mail : ${bleu}$email${reinit}."
		fi
		if ! EXISTS mail ; then
		    DATE-ET-HEURE >> "$bigerror"
