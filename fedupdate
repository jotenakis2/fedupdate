################################################################################################################################
EXISTS() {
	unalias "$1" >/dev/null 2>&1
	command -v "$1" >/dev/null 2>&1
}
################################################################################################################################
CECHO() { # script to write something to stdout in colors
   	local message=$1
   	local color=$2
   	local nonewline=$3
   	if [ "$terminal" != "dumb" ]; then
  		echo -e "$nonewline" "$color$message$reinit"
   	else
  		echo "$nonewline" "$message"
   	fi
   	return 0
}
