################################################# dnf COMMANDS #################################################################
DNF_CLEANCMD() { # nettoyage complet du cache
	local tmp="$HOME/.cache/file.tmp"
	SUDOPASS
	if [ "$silent" = "yes"  ]; then
		# shellcheck disable=SC2024
		sudo $dnf clean all -q >>"$log" 2>>"$logerror" || true
	else
		echo -e "$gris"
		# shellcheck disable=SC2024
		sudo $dnf clean all 2>&1 | tee "$tmp" || true
		echo -ne "$reinit"
		tee -a "$log" "$logerror" < "$tmp" > /dev/null
		rm -f "$tmp"
	fi
	unset tmp
	return 0
}
#-------------------------------------------------------------------------------------------
DNF_CACHEUPDCMD() { # création du cache
	local tmp="$HOME/.cache/file2.tmp"
	SUDOPASS
	if [ "$silent" = "yes"  ]; then
		{ trap STOP-SPINNER EXIT && START-SPINNER; }
			# shellcheck disable=SC2024
			sudo $dnf makecache -q >>"$log" 2>>"$logerror" || true
		{ STOP-SPINNER && echo "terminée."; }
	else
		echo -e "$gris"
		# shellcheck disable=SC2024
		sudo $dnf makecache 2>&1 | tee "$tmp" || true
		echo -ne "$reinit"
		tee -a "$log" "$logerror" < "$tmp" > /dev/null
		rm -f "$tmp"
	fi
	unset tmp
	return 0
}
#-------------------------------------------------------------------------------------------
DNF_CHECKUPDCMD() { # vérification de la présence de mise à jour
	SUDOPASS
	if [ "$silent" = "yes"  ]; then
		# en mode pseudosilencieux je n'affiche rien, je stocke les erreurs et la liste des upd et je met un spinner d'attente
		{ trap STOP-SPINNER EXIT && START-SPINNER; }
			if [ "$changelog" = "" ]; then
				# shellcheck disable=SC2024
				sudo $dnf check-update -q >"$listtmp" 2>>"$logerror" || true
			else
				# shellcheck disable=SC2024
				sudo $dnf check-update --changelogs -q >"$listtmp" 2>>"$logerror" || true
			fi
		{ STOP-SPINNER && echo "terminée."; }
	else
		# en mode normal, j'affiche tout en gris, je stocke les erreurs et la liste des upd (nettoyée)")
		echo -e "$gris"
		if [ "$changelog" = "" ]; then
			# shellcheck disable=SC2024
			sudo $dnf check-update > >(tee "$listtmp" | sed '/^$/d') 2> >(tee -a "$logerror" >&2) || true
		else
			# shellcheck disable=SC2024
			sudo $dnf check-update --changelogs > >(tee "$listtmp" | sed '/^$/d') 2> >(tee -a "$logerror" >&2) || true
		fi
		echo -ne "$reinit"
	fi
	sed -i '/.*|.*|.*|.*/d;/passage de paquets en obsolètes/d;/Obsoleting Packages/d;/^$/d' "$listtmp"
	sed '/^Changelogs/ {x;p;x}' "$listtmp" >> "$log"
	return 0
}
