MAIN(){
    INIT
    MANAGE-ARGS "$@"
    LOAD-CONFIG
    MANAGE-OPTIONS
    [[ -z "${deletelog}" ]] || DELETE-LOG
    [[ -z "${help}" ]]      || HELP
    [[ -z "${checkdeps}" ]] || CHECK
    INTERACTIVE-INIT
