	{ echo "----------------------" ; echo ; } >> "$logFP"
}
################################################################################################################################
INIT-LOGRPM() {
	{ 	DATE-ET-HEURE ;
		echo "$scriptfullname $cmdline (v$ver)" ;
		echo ;
		echo "----------------------" ;
		echo "dnf $dnf, $dnfver, version :" ;
	} >> "$log"
