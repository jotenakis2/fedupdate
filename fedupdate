			CECHO "[WARN]" "$jaune" -n | tee -a "$bigerror" && echo -e " Vous devez aussi installer et configurer un \"Mail Transport Agent\", par exemple ${gras}${bleu}msmtp${reinit} avec la commande ${gras}${bleu}sudo dnf install msmtp${reinit}." | tee -a "$bigerror"
		fi
	fi
	if [ "$checkonly" = "yes" ]; then  # cas mode check-only
		CECHO "[INFO]" "$vert" -n && echo -e " $modeC (${vert}-c${reinit})."
		if [ "$notif_email" = "yes" ]; then
			if [ "$terminal" = "dumb" ]; then # script lancĂŠ en arriĂ¨re plan
				CECHO "[INFO]" "$vert" -n && echo -e " $modeM (${vert}-m${reinit})."
			else # script lancĂŠ en avant plan dans un terminal
				CECHO "[INFO]" "$vert" -n && echo -e " $modeM (${vert}-m${reinit}) ignorĂŠ car le script est lancĂŠ dans un terminal interactif."
				notif_email=""
			fi
		fi
		if [ "$notif" = "yes" ]; then
			CECHO "[INFO]" "$vert" -n && echo -e " $modeN (${vert}-n${reinit})."
		fi
	else # le mode check only n'est pas activĂŠ on ignore donc les notifications
		if [ "$notif_email" = "yes" ]; then
			CECHO "[INFO]" "$vert" -n && echo -e " $modeM (${vert}-m${reinit}) ignorĂŠ car le $modeC (${vert}-c${reinit}) n'est pas activĂŠ."
			notif_email=""
		fi
		if [ "$notif" = "yes" ]; then
			CECHO "[INFO]" "$vert" -n && echo -e " $modeN (${vert}-n${reinit}) ignorĂŠ car le $modeC (${vert}-c${reinit}) n'est pas activĂŠ."
			notif=""
		fi
	fi
	return 0
