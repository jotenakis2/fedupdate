################################################################################################################################
CLEAR-LOGS() {
    local fiche
    nblog=0
    listlog=""
    rm -f "${list}" "${listFP}" "${listRust}"
    if [[ "${limitlog}" = "yes" ]]; then
        [[ "${existupdateFP}" = "" ]] && rm -f "${logFP}"
        [[ "${existupdateRPM}" = "" ]] && rm -f "${log}"
        [[ "${existupdateRust}" = "" ]] && rm -f "${logRust}"
    fi
    for fiche in "${logerrorFP}" "${logerrorRust}" "${logerror}" "${log}" "${logFP}" "${logRust}" "${bigerror}" "${biglog}"; do
        if [[ "${nolog}" = "yes" ]]; then
            rm -f "${fiche}"
        else
            if [[ ! -s "${fiche}" ]]; then # suppression si vide
                rm -f "${fiche}"
            else
                # on compte le nb de log, on ajoute la date ; et on les concatène pour afficher
                if [[ "${fiche}" = "${logerror}" ]] && [[ "${error}" = "yes" ]]; then
                    nblog=$((nblog + 1))
                    echo >>"${fiche}"
                    DATE-ET-HEURE >>"${fiche}"
                    listlog="${listlog}${fiche} "
                elif [[ "${fiche}" != "${logerror}" ]]; then
                    nblog=$((nblog + 1))
                    echo >>"${fiche}"
                    DATE-ET-HEURE >>"${fiche}"
                    listlog="${listlog}${fiche} "
                fi
            fi
        fi
    done
}
