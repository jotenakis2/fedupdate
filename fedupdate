		return 0
	fi
	DNF_UPGRADECMD $VERSION_PLUS
	# Gestion des erreurs de téléchargement
	if [ -s "$logerror" ]; then
		echo
		CECHO "[WARN]" "$jaune" -n && echo " La montée en version a rencontré des erreurs (pas forcément grave, veuillez vérifier) : "
		echo "------------------------"
		$bat "$logerror" || true
		echo "------------------------"
		if ! ASK-YESNO "" "$vert" " Voulez-vous continuer (oui/non) ? " "$magenta" ""; then
			THE-END "des erreurs" || true
			exit 1
		fi
	fi
	if ASK-YESNO " Le script va maintenant redémarrer le système et faire la mise à jour hors-ligne." "$vert" " Êtes-vous d'accord (oui/non) ? " "$magenta" "[INFO]"; then
		echo
		CECHO "[INFO]" "$vert" -n && echo " L'ordinateur va redémarrer dans ${delay}s :"
		if [ "$poweroff" = "yes" ]; then
			COMPTEUR $delay $largeur "==> Redémarrage pour la mise à jour hors-ligne, puis arrêt de l'ordinateur <==" "$gras$jaune" || true
		else
			COMPTEUR $delay $largeur "==> Redémarrage pour la mise à jour hors-ligne, puis allumage de l'ordinateur <==" "$gras$jaune" || true
		fi
		if DNF_CHECK_OFFLINE_UPGRADE_READY; then
			THE-END "succès" || true
			sleep 2 || true
			DNF_UPGRADE-REBOOTCMD
		else
			echo
			CECHO "[ERR.]" "$rouge" -n && echo " Le redémarrage n'est pas possible."
			SUDOPASS
			# shellcheck disable=SC2024
			sudo $dnf offline-upgrade reboot >> "$logerror" 2>&1
			THE-END "des erreurs" || true
			exit 1
		fi
	else
		if ASK-YESNO " Redémarrage annulé par l'utilisateur... " "$vert" " Voulez-vous supprimer les paquets téléchargés non installés (oui/non) ? " "$magenta" "[INFO]"; then
			DNF_UPGRADE-CLEANCMD || true
			CECHO "[INFO]" "$vert" -n && echo " Tous les paquets du cache de mise à jour hors-ligne ont été effacés."
		else
			CECHO "[INFO]" "$vert" -n && echo " Vous pouvez utiliser la commande suivante pour terminer manuellement la mise à jour :"
			echo -e "${bleu}	sudo dnf offline-upgrade -y reboot${reinit}"
			CECHO "[INFO]" "$vert" -n && echo " Vous pouvez utiliser la commande suivante pour supprimer manuellement les paquets téléchargés :"
			echo -e "${bleu}	sudo dnf offline-upgrade clean${reinit}"
		fi
	fi
	return 0
}
################################################################################################################################
CHECKRPM() {
	listtmp="$HOME/.cache/list.tmp"
	if [ -z "$nocacheupd" ]; then
		CECHO "[INFO]" "$vert" -n && echo -n " Mise à jour forcée du cache des métadonnées "
		DNF_CLEANCMD
		DNF_CACHEUPDCMD
	fi
	CECHO "[INFO]" "$vert" -n && echo -n " Vérification des paquets disponibles "
	DNF_CHECKUPDCMD
	# Format and filter list of updates
	if [ "$silent" = "yes" ] && [ "$changelog" = "yes" ]; then
		$bat "$listtmp"
	fi
	awk '/^Changelogs/ {exit} {if (NF > 0) printf "  %-45s %-7s\n", $1, $2}' "$listtmp" > "$list" || true
	rm -f "$listtmp"
	unset listtmp
	# Check for errors and output results
	if [ -s "$logerror" ]; then
		if grep -iqE "$pattern_error" "$logerror"; then
			error="yes"
			CECHO "[ERR.]" "$rouge" -n && echo " La vérification a rencontré des erreurs :"
			echo "------------------------"
			$bat "$logerror" || true
			echo "------------------------"
			echo
			if ! ASK-YESNO "" "$vert" " Voulez-vous continuer (oui/non) ? " "$magenta" ""; then
				THE-END "des erreurs" || true
				exit 1
			fi
		fi
	fi
	if [ -s "$list" ]; then
		existupdateRPM="yes"
		return 0
	else
		return 1
	fi
}
################################################################################################################################
GESTION-RPM() {
	echo
	PRINTBANNER-CENTERED "GESTION DES RPMs" "." "$cyan"
	if CHECKRPM; then
		if [ "$silent" = "yes" ] && [ "$changelog" = "" ] ; then
			$bat "$list" || true
		fi
		if [ -z "$checkonly" ]; then 	# mode normal
			if [ "$directrpms" = "yes" ]; then
				ONLINE-UPGRADE || true
			else
				if [ "$distrupgrade" = "yes" ]; then
			 		CECHO "[INFO]" "$vert" -n && echo -e " Le $modeU est ignoré pour le moment car des mises à jour sont à faire avant."
					CECHO "[INFO]" "$vert" -n && echo -e " Après la mise à jour vous pourrez relancer ${gras}$scriptfullname -u${reinit}."
					distrupgrade=""
				fi
				OFFLINE-UPGRADE || true
			fi
		else  							# mode checkonly
			CECHO "[INFO]" "$vert" -n && echo " Des mises à jour sont disponibles."
			if [ "$distrupgrade" = "yes" ]; then
		 		CECHO "[INFO]" "$vert" -n && echo -e " Le $modeU est ignoré pour le moment car des mises à jour sont à faire avant."
				CECHO "[INFO]" "$vert" -n && echo -e " Après la mise à jour vous pourrez relancer ${gras}$scriptfullname -u${reinit}."
				distrupgrade=""
			fi
			[ "$notif" = "yes" ] && { GESTION-NOTIF "RPM" "$list" || true ;}
			[ "$notif_email" = "yes" ] && { SEND-EMAIL "RPM" "$list" || true ;}
		fi
	else
		CECHO "[INFO]" "$vert" -n && echo -e " ${gras}Votre système ($host) est déjà à jour.${reinit}"
	fi
	return 0
}
################################################################################################################################
GESTION-Flatpak() {
	listtmpFP="$HOME/.cache/listFP.tmp"
	if EXISTS flatpak; then
		flatpak="$(which flatpak 2>/dev/null)"
		INIT-LOGFP || true
		echo
		PRINTBANNER-CENTERED "GESTION DES FLATPAKs" "." "$cyan"
		# Check for available updates
		CECHO "[INFO]" "$vert" -n && echo -n " Vérification des paquets disponibles "
		FPK_CHECKUPDCMD
		#cat "$listtmpFP" | awk '{printf "%-45s %-7s\n", $2, $3}' | sed 's/^/  /' > "$listFP" || true
		#awk '{printf "%-45s %-7s\n", $2, $3}' "$listtmpFP" | sed 's/^/  /' > "$listFP" || true
		awk '{printf "  %-45s %-7s\n", $2, $3}' "$listtmpFP" > "$listFP" || true
		rm -f "$listtmpFP"
		unset listtmpFP
		# Check for verification errors
		if [ -s "$logerrorFP" ]; then
			CECHO "[ERR.]" "$rouge" -n && echo " La vérification a rencontré des erreurs :"
			echo "------------------------"
			$bat "$logerrorFP" || true
			echo "------------------------"
			echo
		else
			if [ -s "$listFP" ]; then # fichier non vide donc il y a des maj
				existupdateFP="yes"
				# Display logs based on `silent` mode
				if [ -n "$silent" ]; then
					$bat "$listFP" || true
				fi
				if [ -z "$checkonly" ]; then
					# Download and install updates
					CECHO "[INFO]" "$vert" -n && echo -n " Mise à jour des paquets "
					FPK_UPDCMD
					# Check for errors during the update process
					if [ -s "$logerrorFP" ]; then
						CECHO "[ERR.]" "$rouge" -n && echo " Le téléchargement a rencontré des erreurs : "
						echo "------------------------"
						$bat "$logerrorFP" || true
						echo "------------------------"
						echo
					fi
				else  # Mode checkonly
					CECHO "[INFO]" "$vert" -n && echo " Des mises à jour sont disponibles."
					[ "$notif" = "yes" ] && { GESTION-NOTIF "FLATPAK" "$listFP" || true ;}
					[ "$notif_email" = "yes" ] && { SEND-EMAIL "FLATPAK" "$listFP" || true ;}
				fi
			else
				CECHO "[INFO]" "$vert" -n && echo -e " ${gras}Votre système ($host) est déjà à jour.${reinit}"
			fi
		fi
	else
		echo
		CECHO "[INFO]" "$vert" -n && echo -e " La commande ${gras}${bleu}flatpak${reinit} n'est pas détectée sur ce système."
		CECHO "[INFO]" "$vert" -n && echo -e " Vous pouvez l'installer avec la commande : ${gras}${bleu}sudo dnf install flatpak${reinit}."
		CECHO "[INFO]" "$vert" -n && echo " En attendant, la gestion des FLATPAKs est désactivée."
	fi
	return 0
}
################################################################################################################################
GESTION-OPTIONS() { # management des options du script sélectionnées via la ligne de commande ou le fichier de conf
	if [ "$datecreated" != "inconnue" ]; then
		CECHO "[INFO]" "$vert" -n
		echo -e " Date d'installation de ${ID^} (${gras}$host${reinit}) :${italic}$datecreated${reinit} (il y a ${days_since_install} $day)" || true
	fi
	CECHO "[INFO]" "$vert" -n && echo -e " Ligne de commande : ${gras}${bleu}${scriptfullname}${reinit} ${gras}${vert}${cmdline}${reinit}" | tee -a "$biglog"

# Affichage des modes selectionnés
	[ "$checkdeps" = "yes" ] && echo -e " $modeCC (${vert}-C${reinit})." >> "$biglog"
	[ "$silent" = "yes" ] && echo -e " $modeS (${vert}-s${reinit})." >> "$biglog"
	[ "$verbose" = "yes" ] && echo -e " $modeV (${vert}-v${reinit})." >> "$biglog"
