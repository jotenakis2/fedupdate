VIEWER() { # par défaut bat cargo, sinon bat système, sinon cat | en arrière-plan => cat
    if [[ "${terminal}" = "dumb" ]]; then
        bat="$(command -v cat 2>/dev/null)"
    else
        if EXISTS bat; then
            [[ -e "${HOME}"/.cargo/bin/bat ]] && bat="${HOME}/.cargo/bin/bat" || bat="$(command -v bat 2>/dev/null)"
            if bat --list-themes 2>/dev/null | grep -iq dracula; then
                bat="${bat} -P -f -n -l log --theme=Dracula"
            else
                bat="${bat} -P -f -n -l log"
            fi
        else
            bat="$(command -v cat 2>/dev/null)"
        fi
    fi
    { DATE-ET-HEURE ; echo "${bat}" ; echo "" ;} >> /tmp/viewer
}
