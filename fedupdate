        fi
        if DNF_CHECK_OFFLINE_UPGRADE_READY; then
            END "succès"
            echo "${dnf}" >"${offlineindicator}" # Ce fichier sera sourcé par un service systemd après reboot pour afficher un message
            echo "${notif_email}" >>"${offlineindicator}"
            sleep 2
            DNF_OFF-REBOOTCMD
        else
            echo
            CECHO "[ERR.]" "${rouge}" -n
            echo " Le redémarrage n'est pas possible."
            SUDOPASS
            # shellcheck disable=SC2024
            sudo "${dnf}" offline-upgrade reboot >>"${logerror}" 2>&1
            tail -n4 "${logerror}"
            END "des erreurs"
            exit 1
        fi
    else
        if ASK-YESNO " Redémarrage annulé par l'utilisateur... " "${vert}" " Voulez-vous supprimer les paquets téléchargés non installés" "${magenta}" "[INFO]"; then
            DNF_OFF-CLEANCMD
            CECHO "[INFO]" "${vert}" -n
