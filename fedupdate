################################################################################################################################
#                   CORPS DU SCRIPT                                                                                            #
################################################################################################################################
INIT
# capture de la ligne de commande (arguments courts)
	while getopts ':shcmnFR0CdB' arguments; do
		case "$arguments" in
			s)	silent="yes"     ;;
			h)  help="yes"       ;;
			c)  checkonly="yes"  ;;
			m)	notif_email="yes";;
			n)  notif="yes"      ;;
			F)	noflatpak="yes"  ;;
			R)	norpm="yes"      ;;
			0)	nolog="yes"      ;;
			C)  checkdeps="yes"  ;;
			d)  directrpms="yes" ;;
			B)  nocacheupd="yes" ;;
			\?) error="yes"      ;;
		esac
	done
	shift "$((OPTIND -1))"
	for arg in "$@"; do
		if [[ "$arg" != -* ]]; then
			error="yes"
		fi
	done
# /capture de la ligne de commande (arguments courts)
GESTION-OPTIONS
[ "$noflatpak" = "" ] && GESTION-FPK
[ "$norpm" = "" ] && GESTION-RPM
THE-END "succès"
exit 0
